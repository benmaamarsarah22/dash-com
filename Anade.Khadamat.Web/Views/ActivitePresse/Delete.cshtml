@model Anade.Khadamat.Domain.Entity.ActivitePresse

@{
    ViewData["Title"] = "حذف الصحافة المكتوبة/الإلكترونية";
    ViewData["FullWidth"] = true;
}

<div class="af-page" dir="rtl">
    
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-pencil-square"></i>
            </div>
            <div>
                <h1 class="af-header-title">حذف الصحافة المكتوبة/الإلكترونية</h1>
                <p class="af-header-sub">الصحافة المكتوبة والإلكترونية</p>
                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <a asp-action="Index">قائمة الصحافة</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">تأكيد الحذف</span>
                </nav>
            </div>
        </div>
    </div>

    <div class="container-fluid px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                
                <partial name="_Message" />

                <div class="card af-card shadow-sm mb-5">
                    <div class="card-body p-4 p-md-5">
                        
                        <div class="alert alert-danger d-flex align-items-center gap-3 mb-4 border-0 shadow-sm" style="border-radius: 12px; background-color: #fff5f5;">
                            <div class="af-stat-icon bg-danger text-white">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-1 text-danger">هل أنت متأكد من الحذف؟</h5>
                                <p class="mb-0 text-dark small">لا يمكن التراجع عن هذا الإجراء بعد التنفيذ. سيتم مسح كافة البيانات المتعلقة بهذا المقال الصحفي.</p>
                            </div>
                        </div>

                        <div class="mb-4">
                            <span class="af-section-title">تفاصيل المقال المراد حذفه</span>
                        </div>

                        <div class="row g-4">
                            <div class="col-12">
                                <label class="text-muted small d-block mb-1">الموضوع</label>
                                <div class="p-3 bg-light rounded-3 fw-bold">@Model.Activite?.Sujet</div>
                            </div>

                            <div class="col-md-6">
                                <label class="text-muted small d-block mb-1">الصحيفة / الموقع الإلكتروني</label>
                                <div class="p-2 border-bottom"><i class="bi bi-newspaper me-2 text-primary"></i> @Model.Media</div>
                            </div>

                            <div class="col-md-6">
                                <label class="text-muted small d-block mb-1">تاريخ النشر</label>
                                <div class="p-2 border-bottom"><i class="bi bi-calendar-event me-2 text-primary"></i> @Model.Activite?.DateActivite.ToString("dd/MM/yyyy")</div>
                            </div>

                            <div class="col-md-6">
                                <label class="text-muted small d-block mb-1">الهيئة</label>
                                <div class="p-2 border-bottom"><i class="bi bi-building me-2 text-primary"></i> @Model.Activite?.AgenceWilaya?.DesignationAr</div>
                            </div>

                        </div>

                        <hr class="my-5 opacity-10">

                        <form asp-action="DeleteConfirmed" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            
                            <div class="d-flex gap-3 justify-content-end">
                                <a asp-action="Index" class="btn btn-light px-4 fw-bold text-secondary">
                                    <i class="bi bi-arrow-right-circle me-1"></i> تراجع
                                </a>
                                <button type="submit" class="btn btn-danger px-5 fw-bold shadow-sm" id="btnConfirmDelete">
                                    <i class="bi bi-trash3 me-1"></i> تأكيد الحذف النهائي
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnConfirmDelete').addEventListener('click', function() {
            const btn = this;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status"></span> جاري الحذف...`;
            btn.classList.add('disabled');
        });
    </script>
}