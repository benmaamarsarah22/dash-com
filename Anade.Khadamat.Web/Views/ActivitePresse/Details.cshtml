@model Anade.Khadamat.Domain.Entity.ActivitePresse

@{
    ViewData["Title"] = "تفاصيل الصحيفة / الموقع الإلكتروني";
}

<div class="container mt-4" dir="rtl">

    <div class="card shadow border-0 rounded-4">

        <!-- Header -->
        <div class="card-header bg-primary text-white text-center rounded-top-4">
            <h4 class="mb-0">📄تتفاصيل الصحيفة / الموقع الإلكتروني</h4>
        </div>

        <!-- Body -->
        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-6">

                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light">
                            <strong>📍 الصحيفة / الموقع الإلكتروني</strong>
                            <div>@Model.Media</div>
                        </div>
                    </div>

                    <div class="p-3 border rounded bg-light">
                        <strong>📌 موضوع  </strong>
                        <div>@Model.Activite.Sujet</div>
                    </div>
                </div>

                 

                <div class="col-md-6">
                    <div class="p-3 border rounded bg-light">
                        <strong>📅 التاريخ</strong>
                        <div>@Model.Activite.DateActivite.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>

 


            </div>

        </div>

        <!-- Button -->
        <div class="text-start mt-4">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                ⬅ رجوع
            </a>
        </div>

    </div>
</div>

</div>