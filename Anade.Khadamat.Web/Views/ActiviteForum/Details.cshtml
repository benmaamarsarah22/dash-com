@model Anade.Khadamat.Domain.Entity.ActiviteForum

@{
    ViewData["Title"] = "Détails Journée d’étude et forum";
}

<div class="card shadow-lg border-0 p-4">
    <div class="card-header bg-info text-white">
        <h3 class="mb-0">📄تفاصيل أيام دراسية وملتقيات – منتدى</h3>
    </div>

    <!-- Body -->
    <div class="card-body">

        <div class="row g-3">

            <div class="col-md-6">
                <div class="p-3 border rounded bg-light">
                    <strong>📌 موضوع النشاط</strong>
                    <div>@Model.Activite.Sujet</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded bg-light">
                    <strong>📍 المكان</strong>
                    <div>@Model.Activite.Lieu</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded bg-light">
                    <strong>📅 التاريخ</strong>
                    <div>@Model.Activite.DateActivite.ToString("dd/MM/yyyy")</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded bg-light">
                    <strong>👥 المنظمون</strong>
                    <div>@Model.Activite.Organisateurs</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded bg-light">
                    <strong>🙋 المشاركون</strong>
                    <div>@Model.Activite.Participants</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded bg-light">
                    <strong>📊 عدد الزوار</strong>
                    <div>@Model.Activite.NombreVisiteurs</div>
                </div>
            </div>

        </div>

        <!-- Button -->
        <div class="text-start mt-4">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                ⬅ رجوع
            </a>
        </div>
    </div>
</div>
