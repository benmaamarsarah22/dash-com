@model IEnumerable<Anade.Khadamat.Domain.Entity.ActiviteForum>

@{
    ViewData["Title"] = "أيام دراسية وملتقيات";
    ViewData["FullWidth"] = true;
}

@section head {
    <partial name="_datatables.style" />
    
}

<div class="af-page" dir="rtl">

    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-people"></i>
            </div>
            <div>
                <h1 class="af-header-title">أيام دراسية وملتقيات</h1>
                <p class="af-header-sub">قائمة جميع الأيام الدراسية والملتقيات المسجلة</p>
                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                 
                    <span style="color:rgba(255,255,255,.75)">أيام دراسية وملتقيات</span>
                </nav>
            </div>
        </div>
        <a asp-controller="ActiviteForum" asp-action="Create" class="btn-af-add">
            <i class="bi bi-plus-circle-fill"></i>
            إضافة نشاط جديد
        </a>
    </div>

    <div class="container-fluid px-4 px-lg-5">

       

        <div class="af-card">
            <div class="card-body p-4">

                <partial name="_Message" />

                <div class="af-section-wrap">
                    <div class="py-2">
                        <span class="text-primary fw-medium" style="font-size:.75rem;letter-spacing:.8px;text-transform:uppercase;">
                            <i class="bi bi-list-ul me-1"></i>
                        </span>
                        <span class="af-section-title">قائمة النشاطات</span>
                    </div>
                </div>

                <div class="table">
                    <table class="table table-hover table-bordered tableDashboard align-middle w-100" id="myTable">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th><i class="bi bi-building ms-1"></i> الهيئة</th>
                                <th><i class="bi bi-chat-square-text ms-1"></i> موضوع التظاهرة</th>
                                <th><i class="bi bi-geo-alt ms-1"></i> مكان التظاهرة</th>
                                <th><i class="bi bi-calendar3 ms-1"></i> التاريخ</th>
                                <th><i class="bi bi-person-badge ms-1"></i> المنظمين</th>
                                <th><i class="bi bi-people ms-1"></i> المشاركين</th>
                                <th><i class="bi bi-eye ms-1"></i> عدد الزوار</th>
                                <th><i class="bi bi-sliders ms-1"></i> إجراءات</th>
                            </tr>
                        </thead>
                        <tbody class="table-group-divider"></tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_datatables.script" />
    <script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {

            $('#myTable').DataTable({
                processing: true,
                serverSide: true,
                order: [[0, "desc"]],
                lengthMenu: [[10, 20, 50, 9999], [10, 20, 50, "الكل"]],
                ajax: {
                    url: "/ActiviteForum/ForumDataTable",
                    type: "POST",
                    dataSrc: function (json) {
                        if (json.data) {
                            var totP = 0, totO = 0, totV = 0;
                            json.data.forEach(function (r) {
                                totP += parseInt(r.activite?.participants    || 0);
                                totO += parseInt(r.activite?.organisateurs   || 0);
                                totV += parseInt(r.activite?.nombreVisiteurs || 0);
                            });
                            $('#stat-total').text(json.recordsTotal ?? json.data.length);
                            $('#stat-participants').text(totP.toLocaleString('ar-DZ'));
                            $('#stat-organisateurs').text(totO.toLocaleString('ar-DZ'));
                            $('#stat-visitors').text(totV.toLocaleString('ar-DZ'));
                        }
                        return json.data;
                    }
                },
                columns: [
                    { data: "id", visible: false, searchable: false },
                    {
                        data: "activite.agenceWilaya.designationAr",
                        render: function (data) {
                            return `<span class="fw-medium">${data ?? ''}</span>`;
                        }
                    },
                    {
                        data: "activite.sujet",
                        render: function (data) {
                            return `<span class="fw-semi-bold text-dark">${data ?? ''}</span>`;
                        }
                    },
                    {
                        data: "activite.lieu",
                        render: function (data) {
                            return `<span class="text-muted">
                                        <i class="bi bi-geo-alt-fill me-1" style="color:var(--primary)"></i>${data ?? ''}
                                    </span>`;
                        }
                    },
                    {
                        data: "activite.dateActivite",
                        render: function (data) {
                            return `<span class="date-badge">
                                        <i class="bi bi-calendar3"></i>
                                        ${moment(data).format('DD/MM/YYYY')}
                                    </span>`;
                        }
                    },
                    {
                        data: "activite.organisateurs",
                        render: function (data) {
                            return `<span class="info-pill">
                                        <i class="bi bi-person-badge-fill"></i>${data ?? 0}
                                    </span>`;
                        }
                    },
                    {
                        data: "activite.participants",
                        render: function (data) {
                            return `<span class="info-pill">
                                        <i class="bi bi-people-fill"></i>${data ?? 0}
                                    </span>`;
                        }
                    },
                    {
                        data: "activite.nombreVisiteurs",
                        render: function (data) {
                            return `<span class="visitor-count">
                                        <i class="bi bi-eye-fill" style="color:var(--primary)"></i>
                                        ${(data ?? 0).toLocaleString('ar-DZ')}
                                    </span>`;
                        }
                    },
                    {
                        data: "id",
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row) {
                            return `
                                <div class="d-flex gap-1 justify-content-center">
                                    <a href="/ActiviteForum/Details/${row.id}"
                                       class="btn-af-action btn-af-view"
                                       data-bs-toggle="tooltip" title="تفاصيل">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a href="/ActiviteForum/Edit/${row.id}"
                                       class="btn-af-action btn-af-edit"
                                       data-bs-toggle="tooltip" title="تعديل">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/ActiviteForum/Delete/${row.id}"
                                       class="btn-af-action btn-af-del"
                                       data-bs-toggle="tooltip" title="حذف">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>`;
                        }
                    }
                ],
                language: {
                    sProcessing:     "جارٍ المعالجة...",
                    sSearch:         "بحث&nbsp;:",
                    sLengthMenu:     "عرض _MENU_ عنصر",
                    sInfo:           "عرض _START_ إلى _END_ من أصل _TOTAL_ عنصر",
                    sInfoEmpty:      "عرض 0 إلى 0 من أصل 0 عنصر",
                    sInfoFiltered:   "(مصفى من إجمالي _MAX_ عنصر)",
                    sLoadingRecords: "جارٍ التحميل...",
                    sZeroRecords:    "لم يتم العثور على نتائج",
                    sEmptyTable:     "لا توجد بيانات متاحة",
                    oPaginate: {
                        sFirst:    "الأول",
                        sPrevious: "السابق",
                        sNext:     "التالي",
                        sLast:     "الأخير"
                    }
                },
                dom: 'Blfrtip',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: '<i class="bi bi-file-earmark-excel-fill me-1"></i> تصدير Excel',
                        title: 'قائمة_أيام_دراسية_وملتقيات',
                        className: 'btn btn-success btn-sm',
                        autoFilter: true,
                        exportOptions: { columns: [1, 2, 3, 4, 5, 6] }
                    }
                ],
                drawCallback: function () {
                    $('[data-bs-toggle="tooltip"]').tooltip('dispose').tooltip();
                }
            });

            $('[data-bs-toggle="tooltip"]').tooltip();
        });
    </script>
}