@{
    ViewData["Title"] = "الرئيسية";
    ViewData["FullWidth"] = true;
}

<style>
    /* ─── Hero ─── */
    #hero {
        background: linear-gradient(150deg, rgba(22, 30, 130, 0.90) 0%, rgba(78, 87, 212, 0.78) 100%),
                    url(/NesdaAcademyTemplette/img/hero-1.jpg) center / cover no-repeat;
        min-height: 100vh;
        display: flex;
        align-items: center;
        text-align: center;
    }
    #hero .hero-eyebrow {
        letter-spacing: 3px;
        font-size: .8rem;
        opacity: .75;
    }

    /* ─── Section label ─── */
    .section-label {
        letter-spacing: 2px;
        font-size: .78rem;
    }
    .label-bar {
        display: block;
        width: 40px;
        height: 3px;
        border-radius: 2px;
        background: var(--bs-primary);
        margin: .6rem auto 0;
    }

    /* ─── About image ─── */
    .about-frame {
        border-radius: 20px;
        overflow: hidden;
        height: 400px;
        box-shadow: 0 24px 64px rgba(78, 87, 212, .15);
    }
    .about-frame img { width: 100%; height: 100%; object-fit: cover; }

    /* ─── Service cards ─── */
    .srv-card {
        border: 1.5px solid #e9ecef;
        border-radius: 18px;
        padding: 2rem 1.5rem;
        background: #fff;
        text-align: center;
        height: 100%;
        transition: transform .3s ease, border-color .3s ease, box-shadow .3s ease;
        cursor: default;
    }
    .srv-card:hover {
        transform: translateY(-7px);
        border-color: rgba(78, 87, 212, .4);
        box-shadow: 0 0 0 4px rgba(78, 87, 212, .07),
                    0 20px 48px rgba(78, 87, 212, .13);
    }
    .srv-icon {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        background: rgba(78, 87, 212, .09);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
        font-size: 1.55rem;
        color: #4e57d4;
        transition: transform .35s ease, background .35s ease, box-shadow .35s ease;
    }
    .srv-card:hover .srv-icon {
        background: rgba(78, 87, 212, .18);
        transform: scale(1.12);
        box-shadow: 0 0 0 7px rgba(78, 87, 212, .09);
    }
    .srv-card h6 { font-size: .95rem; }
    .srv-card p  { font-size: .84rem; line-height: 1.6; }
</style>

<!-- ═══════════════ HERO ═══════════════ -->
<section id="hero">
    <div class="container py-5">
        <p class="text-white hero-eyebrow text-uppercase mb-3 fw-600">
            الوكالة الوطنية لدعم وتنمية المقاولاتية
        </p>
        <h1 class="display-2 fw-bold text-white mb-4">NESDA Dash-com</h1>
        <p class="text-white opacity-90 mb-5 mx-auto" style="max-width:540px; line-height:1.75; font-size:1.05rem;">
            منصة متابعة وتحليل أداء الاتصال — تجمع المؤشرات الرئيسية وتُقدّم الإحصاءات في الوقت الفعلي
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Dashboard" class="btn btn-light btn-lg fw-600 px-5 rounded-pill">الأنشطة</a>
            <a href="#about" class="btn btn-outline-light btn-lg px-5 rounded-pill">حول المنصة</a>
        </div>
    </div>
</section>

<!-- ═══════════════ ABOUT ═══════════════ -->
<section id="about" class="py-5">
    <div class="container py-4">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5">
                <div class="about-frame">
                    <img src="/NesdaAcademyTemplette/img/logo.png" alt="NESDA" />
                </div>
            </div>
            <div class="col-lg-7">
                <p class="text-primary section-label text-uppercase fw-600 mb-2">حول المنصة</p>
                <h2 class="fw-bold mb-4">NESDA Dash-com</h2>
                <p class="text-muted mb-4" style="line-height:1.85; font-size:.98rem;">
                    هي منصة مصممة لتجميع المعلومات وعرض البيانات الخاصة بحملات الاتصال، حيث تتيح متابعة مؤشرات الأداء الرئيسية (KPI) في الوقت الفعلي. توفر المنصة إمكانية تحليل سريع وفعّال لتأثير الإجراءات التواصلية داخلياً وخارجياً، مما يسهل اتخاذ القرار وتحسين الاستراتيجيات.
                </p>
                <a href="/Dashboard" class="btn btn-primary px-5 rounded-pill">استكشف الأنشطة</a>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════ SERVICES ═══════════════ -->
<section class="py-5" style="background:#f8f9fc;">
    <div class="container py-4">
        <div class="text-center mb-5">
            <p class="text-primary section-label text-uppercase fw-600 mb-2">ما نقوم به</p>
            <h2 class="fw-bold">أنشطة الاتصال</h2>
            <span class="label-bar"></span>
        </div>

        <div class="row g-4">
            <div class="col-lg-3 col-sm-6">
                <div class="srv-card">
                    <div class="srv-icon"><i class="bi bi-bar-chart-line"></i></div>
                    <h6 class="fw-700 mb-2">إحصائيات الوكالات</h6>
                    <p class="text-muted mb-0">عرض شامل لأنشطة الوكالات مع مؤشرات أداء محدثة على المستوى الوطني</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="srv-card">
                    <div class="srv-icon"><i class="bi bi-calendar-event"></i></div>
                    <h6 class="fw-700 mb-2">أيام إعلامية وأبواب مفتوحة</h6>
                    <p class="text-muted mb-0">أيام إعلامية لمرافقة الشباب في تطوير مشاريعهم والتعريف بخدماتنا</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="srv-card">
                    <div class="srv-icon"><i class="bi bi-collection"></i></div>
                    <h6 class="fw-700 mb-2">معارض وصالونات</h6>
                    <p class="text-muted mb-0">مشاركة في المعارض والصالونات لعرض الخدمات ودعم أصحاب المشاريع</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="srv-card">
                    <div class="srv-icon"><i class="bi bi-people"></i></div>
                    <h6 class="fw-700 mb-2">أيام دراسية وملتقيات</h6>
                    <p class="text-muted mb-0">ملتقيات لتبادل الخبرات وتعزيز التواصل بين مختلف الفاعلين</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="srv-card">
                    <div class="srv-icon"><i class="fas fa-handshake"></i></div>
                    <h6 class="fw-700 mb-2">جلسات تنسيقية خارجية /اتفاقيات</h6>
                    <p class="text-muted mb-0">جلسات تنسيق واتفاقيات شراكة لتعزيز التعاون وتحقيق أهداف مشتركة</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="srv-card">
                    <div class="srv-icon"><i class="bi bi-broadcast"></i></div>
                    <h6 class="fw-700 mb-2">تغطيات إذاعية</h6>
                    <p class="text-muted mb-0">مواكبة الأنشطة عبر التغطيات الإذاعية لتعزيز التواصل مع الجمهور</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="srv-card">
                    <div class="srv-icon"><i class="bi bi-camera-video"></i></div>
                    <h6 class="fw-700 mb-2">تغطيات تلفزيونية</h6>
                    <p class="text-muted mb-0">إبراز الأنشطة عبر التغطيات التلفزيونية للتعريف ببرامجنا ومبادراتنا</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="srv-card">
                    <div class="srv-icon"><i class="bi bi-newspaper"></i></div>
                    <h6 class="fw-700 mb-2">صحافة مكتوبة/إلكترونية</h6>
                    <p class="text-muted mb-0">نشر الأنشطة عبر الصحافة المكتوبة والإلكترونية لضمان وصول أوسع للمعلومة</p>
                </div>
            </div>
        </div>
    </div>
</section>