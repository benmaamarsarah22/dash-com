@model List<Anade.Khadamat.Domain.Entity.MoisCloture>

@using Anade.Khadamat.Identity

@using Microsoft.AspNetCore.Identity

@inject SignInManager<User> SignInManager

@{
    ViewData["Title"] = "إدارة الأشهر";
    var currentYear = DateTime.Now.Year;
    var currentMonth = DateTime.Now.Month;
}

@section head {
    <style>
        /* ─── Card ring animation ─── */
        .month-card {
            border: 2px solid #e9ecef;
            border-radius: 18px;
            background: #fff;
            transition: transform .28s ease, border-color .28s ease, box-shadow .28s ease;
            overflow: hidden;
            position: relative;
        }
        .month-card::before {
            content: '';
            position: absolute;
            inset: -2px;
            border-radius: 20px;
            background: transparent;
            transition: box-shadow .28s ease;
            pointer-events: none;
            z-index: 0;
        }
        .month-card:hover {
            transform: translateY(-5px);
            border-color: rgba(78, 87, 212, .45);
            box-shadow: 0 0 0 5px rgba(78, 87, 212, .08),
                        0 16px 40px rgba(78, 87, 212, .14);
        }
        .month-card.is-closed:hover {
            border-color: rgba(220, 53, 69, .45);
            box-shadow: 0 0 0 5px rgba(220, 53, 69, .07),
                        0 16px 40px rgba(220, 53, 69, .12);
        }
        .month-card .card-body,
        .month-card .card-footer,
        .month-card .mc-header { position: relative; z-index: 1; }

        /* ─── Card header ─── */
        .mc-header {
            padding: 1.1rem 1.25rem;
            border-bottom: 1px solid #f0f0f0;
        }
        .month-name { font-size: 1.05rem; font-weight: 700; }
        .month-year { font-size: .78rem; color: #999; }

        /* ─── Audit rows ─── */
        .audit-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: .45rem 0;
            font-size: .84rem;
        }
        .audit-row:not(:last-child) { border-bottom: 1px solid #f4f4f4; }
        .audit-label { color: #aaa; }
        .audit-value { font-weight: 600; color: #333; text-align: left; direction: ltr; }

        /* ─── Reopen banner ─── */
        .reopen-banner {
            background: rgba(255, 193, 7, .08);
            border: 1px solid rgba(255, 193, 7, .3);
            border-radius: 10px;
            padding: .6rem .9rem;
            margin-top: .75rem;
        }
        .reopen-banner .rb-label { font-size: .78rem; color: #b08000; }
        .reopen-banner .rb-value  { font-size: .84rem; font-weight: 600; color: #5a4200; }

        /* ─── Open-form card ─── */
        .open-form-card {
            border: none;
            border-radius: 18px;
            background: linear-gradient(135deg, #0d6efd 0%, #5282ff 100%);
        }
    </style>
}

<div class="container-fluid py-4" dir="rtl">

    <partial name="_Message" />

    @* ── Open new month ── *@
    <div class="open-form-card shadow mb-5 p-4">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-calendar2-plus text-white fs-5"></i>
            <h5 class="mb-0 text-white fw-700">فتح شهر جديد</h5>
        </div>
        <form asp-controller="MoisCloture" asp-action="Ouvrir" method="post" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <label class="form-label text-white opacity-75 small fw-600">السنة</label>
                <select name="annee" class="form-select border-0 shadow-sm">
                    @for (int y = currentYear + 2; y >= currentYear - 3; y--)
                    {
                        <option value="@y" selected="@(y == currentYear ? "selected" : null)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label text-white opacity-75 small fw-600">الشهر</label>
                <select name="mois" class="form-select border-0 shadow-sm">
                    @{
                        var monthNames = new[] { "جانفي", "فيفري", "مارس", "أفريل", "ماي", "جوان", "جويلية", "أوت", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر" };
                        for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == currentMonth ? "selected" : null)">@monthNames[m - 1]</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-light fw-700 w-100 rounded-pill">
                    <i class="bi bi-unlock me-2"></i>فتح
                </button>
            </div>
        </form>
    </div>

    @* ── Months list ── *@
    <div class="d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-calendar3 text-primary fs-5"></i>
        <h5 class="mb-0 fw-700">الأشهر المسجلة</h5>
    </div>

    <div class="row g-3">
        @if (Model.Count == 0)
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-4 rounded-3">
                    <i class="bi bi-calendar-check fs-5 me-2"></i>
                    لا توجد أشهر مسجلة حتى الآن
                </div>
            </div>
        }
        @foreach (var item in Model.OrderByDescending(x => x.Annee).ThenByDescending(x => x.Mois))
        {
            var isReopened = !item.IsCloture && item.DateReouverture.HasValue;
            <div class="col-lg-4 col-md-6">
                <div class="card month-card shadow-sm h-100 @(item.IsCloture ? "is-closed" : "")">

                    @* ── Header ── *@
                    <div class="mc-header d-flex justify-content-between align-items-center">
                        <div>
                            <div class="month-name">@item.MoisLabel</div>
                            <div class="month-year">@item.Annee</div>
                        </div>
                        @if (item.IsCloture)
                        {
                            <span class="badge bg-danger px-3 py-2 rounded-pill fs-xs">
                                <i class="bi bi-lock-fill me-1"></i>مغلق
                            </span>
                        }
                        else if (isReopened)
                        {
                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fs-xs">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>أُعيد فتحه
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success px-3 py-2 rounded-pill fs-xs">
                                <i class="bi bi-unlock-fill me-1"></i>مفتوح
                            </span>
                        }
                    </div>

                    @* ── Body ── *@
                    <div class="card-body px-3 py-3">
                        @if (item.IsCloture)
                        {
                            @if (item.DateCloture.HasValue)
                            {
                                <div class="audit-row">
                                    <span class="audit-label">أُغلق في</span>
                                    <span class="audit-value">@item.DateCloture.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(item.CloturePar))
                            {
                                <div class="audit-row">
                                    <span class="audit-label">بواسطة</span>
                                    <span class="audit-value">@item.CloturePar</span>
                                </div>
                            }
                            @if (item.DateReouverture.HasValue)
                            {
                                <div class="audit-row">
                                    <span class="audit-label">أعيد فتحه في</span>
                                    <span class="audit-value">@item.DateReouverture.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(item.ReouvertPar))
                            {
                                <div class="audit-row">
                                    <span class="audit-label">أعاد الفتح</span>
                                    <span class="audit-value">@item.ReouvertPar</span>
                                </div>
                            }
                        }
                        else if (isReopened)
                        {
                            @* Open but was previously reopened — show reopen audit *@
                            <div class="reopen-banner">
                                <div class="rb-label mb-1">
                                    <i class="bi bi-arrow-counterclockwise me-1"></i>أُعيد فتح هذا الشهر
                                </div>
                                @if (item.DateReouverture.HasValue)
                                {
                                    <div class="audit-row py-1">
                                        <span class="audit-label">في</span>
                                        <span class="rb-value">@item.DateReouverture.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(item.ReouvertPar))
                                {
                                    <div class="audit-row py-1">
                                        <span class="audit-label">بواسطة</span>
                                        <span class="rb-value">@item.ReouvertPar</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* ── Footer ── *@
                    <div class="card-footer bg-transparent border-top py-2 px-3">
                        @if (!item.IsCloture)
                        {

                            @if (SignInManager.IsSignedIn(User))
                            {
                                @if (User.IsInRole("CommunicationDG"))
                                {
                                    <form asp-controller="MoisCloture" asp-action="Cloturer" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="annee" value="@item.Annee" />
                                        <input type="hidden" name="mois" value="@item.Mois" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger w-100 rounded-pill"
                                                onclick="return confirm('تأكيد إغلاق @item.MoisLabel ؟')">
                                            <i class="bi bi-lock-fill me-1"></i>إغلاق
                                        </button>
                                    </form>
                                   
                                }


                            }
                            else if (User.IsInRole("Admin"))
                            {
                                <form asp-controller="MoisCloture" asp-action="Cloturer" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="annee" value="@item.Annee" />
                                    <input type="hidden" name="mois" value="@item.Mois" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100 rounded-pill"
                                            onclick="return confirm('تأكيد إغلاق @item.MoisLabel ؟')">
                                        <i class="bi bi-lock-fill me-1"></i>إغلاق
                                    </button>
                                </form>

                            }
                            else
                            {
                               
                            }




                          
                        }
                        else
                        {
                            @if (SignInManager.IsSignedIn(User))
                            {
                                @if (User.IsInRole("CommunicationDG"))
                                {
                                    <form asp-controller="MoisCloture" asp-action="Reouvrir" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="annee" value="@item.Annee" />
                                        <input type="hidden" name="mois" value="@item.Mois" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning w-100 rounded-pill"
                                                onclick="return confirm('تأكيد إعادة فتح @item.MoisLabel ؟')">
                                            <i class="bi bi-arrow-counterclockwise me-1"></i>إعادة فتح
                                        </button>
                                    </form>

                                }


                            }
                            else if (User.IsInRole("Admin"))
                            {
                                <form asp-controller="MoisCloture" asp-action="Reouvrir" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="annee" value="@item.Annee" />
                                    <input type="hidden" name="mois" value="@item.Mois" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning w-100 rounded-pill"
                                            onclick="return confirm('تأكيد إعادة فتح @item.MoisLabel ؟')">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i>إعادة فتح
                                    </button>
                                </form>

                            }
                            else
                            {

                            }


 
                        }
                    </div>

                </div>
            </div>
        }
    </div>

</div>

