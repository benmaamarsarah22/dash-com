@model List<Anade.Khadamat.Domain.Entity.MoisCloture>

@using Anade.Khadamat.Identity

@using Microsoft.AspNetCore.Identity

@inject SignInManager<User> SignInManager

@{
    ViewData["Title"] = "إدارة الأشهر";
    ViewData["FullWidth"] = true;
    var currentYear = DateTime.Now.Year;
    var currentMonth = DateTime.Now.Month;
}

 
<style>
   
    /* Ajustements spécifiques pour cette page */
    .border-top-primary {
        border-top: 4px solid var(--primary) !important;
    }
    
    .transition-all {
        transition: all 0.3s ease;
    }
    
    .af-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
    }

    .bg-danger-subtle { background-color: rgba(220, 53, 69, 0.1); }
    .bg-success-subtle { background-color: rgba(25, 135, 84, 0.1); }
    .bg-warning-subtle { background-color: rgba(255, 193, 7, 0.1); }
</style>
 

<div class="af-page" dir="rtl">

    <!-- HEADER -->
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-calendar3"></i>
            </div>
            <div>
                <h1 class="af-header-title">إدارة الأشهر</h1>
                <p class="af-header-sub">فتح وإغلاق الأشهر وإدارة دورة الإدخال</p>
                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">إدارة الأشهر</span>
                </nav>
            </div>
        </div>
    </div>

    <div class="container">

    <partial name="_Message" />



    @* ── Section : Ouvrir un nouveau mois ── *@


    <div class="af-card shadow-sm mb-5">
        <div class="card-header bg-dark py-3 px-4">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-plus-circle-dotted text-primary fs-5"></i>
                <h5 class="mb-0 text-white fw-700">فتح شهر جديد</h5>
            </div>
        </div>
        <div class="card-body p-4">
            <form asp-controller="MoisCloture" asp-action="Ouvrir" method="post" class="row g-4 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                    <label class="form-label fw-600 small">السنة </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-calendar-event"></i></span>
                        <select name="annee" class="form-select af-form-input shadow-none">
                            @for (int y = DateTime.Now.Year + 1; y >= DateTime.Now.Year - 2; y--)
                            {
                                <option value="@y" selected="@(y == DateTime.Now.Year ? "selected" : null)">@y</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-600 small">الشهر المستهدف</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi- moon-stars"></i></span>
                        <select name="mois" class="form-select af-form-input shadow-none">
                            @{
                                var monthNames = new[] { "جانفي", "فيفري", "مارس", "أفريل", "ماي", "جوان", "جويلية", "أوت", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر" };
                                for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m" selected="@(m == DateTime.Now.Month ? "selected" : null)">@monthNames[m - 1]</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn-af-add w-100 justify-content-center py-2">
                        <i class="bi bi-unlock"></i> فتح شهر جديد
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* ── Section : Liste des mois ── *@
    <div class="af-section-wrap">
        <h6 class="af-section-title">السجل التاريخي للأشهر</h6>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <img src="/img/empty-calendar.svg" alt="Empty" style="width: 150px; opacity: 0.5;">
                <p class="text-muted mt-3 fw-600">لا توجد بيانات مسجلة حالياً</p>
            </div>
        }
        
        @foreach (var item in Model.OrderByDescending(x => x.Annee).ThenByDescending(x => x.Mois))
        {
            var isReopened = !item.IsCloture && item.DateReouverture.HasValue;
            
            <div class="col-lg-4 col-md-6">
                <div class="af-card h-100 transition-all border-top-primary">
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h4 class="fw-bold mb-0 text-dark">@item.MoisLabel</h4>
                                <span class="date-badge mt-1">@item.Annee</span>
                            </div>
                            @if (item.IsCloture)
                            {
                                <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill border border-danger">
                                    <i class="bi bi-lock-fill"></i> مغلق
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill border border-success">
                                    <i class="bi bi-unlock-fill"></i> مفتوح
                                </span>
                            }
                        </div>

                        <hr class="opacity-10">

                        <div class="audit-trail mt-3">
                            @if (item.IsCloture)
                            {
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <div class="af-stat-icon bg-light text-danger" style="width:32px; height:32px; font-size: 0.9rem;">
                                        <i class="bi bi-person-x"></i>
                                    </div>
                                    <div class="small">
                                        <div class="text-muted small">أُغلق بواسطة</div>
                                        <div class="fw-700 text-dark">@(item.CloturePar ?? "النظام")</div>
                                    </div>
                                </div>
                            }
                            
                            @if (isReopened)
                            {
                                <div class="info-pill bg-warning-subtle text-warning border-warning w-100 justify-content-center py-2 mb-2">
                                    <i class="bi bi-exclamation-triangle me-1"></i> أُعيد فتحه بتاريخ @item.DateReouverture.Value.ToString("dd/MM")
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card-footer bg-light border-0 p-3">
                        @if (!item.IsCloture)
                        {
                            @if (User.IsInRole("Admin") || User.IsInRole("CommunicationDG"))
                            {
                                <form asp-controller="MoisCloture" asp-action="Cloturer" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="annee" value="@item.Annee" />
                                    <input type="hidden" name="mois" value="@item.Mois" />
                                    <button type="submit" class="btn btn-outline-danger w-100 rounded-pill btn-sm fw-700" 
                                            onclick="return confirm('تأكيد إغلاق الشهر؟')">
                                        <i class="bi bi-lock-fill me-1"></i> إغلاق الفترة الآن
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            @if (User.IsInRole("Admin") || User.IsInRole("CommunicationDG"))
                            {
                                <form asp-controller="MoisCloture" asp-action="Reouvrir" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="annee" value="@item.Annee" />
                                    <input type="hidden" name="mois" value="@item.Mois" />
                                    <button type="submit" class="btn btn-outline-warning w-100 rounded-pill btn-sm fw-700"
                                            onclick="return confirm('تأكيد إعادة فتح الشهر؟')">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i> طلب إعادة فتح
                                    </button>
                                </form>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
</div>
