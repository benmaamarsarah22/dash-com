@model Anade.Khadamat.Web.ViewModels.DashboardFilterVM

@{
    ViewData["Title"] = "Dashboard Activités";
}

@section head {
    <partial name="_datatables.style" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css">

    <style>
        .act-form-page {
            background: linear-gradient(160deg,#eef2ff 0%,#f8f9fa 60%);
            min-height: calc(100vh - 64px);
        }

        .act-form-card {
            border-radius: 18px;
            overflow: hidden;
            border: none;
        }

        .act-form-header {
            background: linear-gradient(135deg,#4e57d4 0%,#6a76ef 100%);
            padding: 1.75rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .act-form-header-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .act-form-header-icon {
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,.18);
            border-radius: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.35rem;
            color: #fff;
        }

        .act-form-header-title {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0;
        }

        .act-form-header-sub {
            color: rgba(255,255,255,.68);
            font-size: .78rem;
            margin: .15rem 0 0;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            line-height: 1.5;
        }

        .act-section-divider {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .9px;
            color: #9099b5;
            padding-bottom: .45rem;
            border-bottom: 1.5px solid #eaecf4;
            margin-bottom: 1rem;
        }

        #dashboardTable thead th {
            background: #4e57d4;
            color: #fff;
            font-size: .95rem;
            font-weight: 700;
            text-align: center;
            vertical-align: middle;
        }

        #dashboardTable tbody tr:hover {
            background: #f0f2ff;
        }

        #dashboardTable tbody td {
            text-align: center;
            vertical-align: middle;
            font-size: .95rem;
        }

        .btn-excel-custom {
            background: #caf8f7 !important;
            border-radius: 5px !important;
            border: none !important;
            margin: 5px !important;
        }

            .btn-excel-custom span {
                color: #000 !important;
            }

        .btn-tasfiya {
            background: #4e57d4 !important;
            border-radius: 5px !important;
            transition: 0.2s ease-in-out;
            color: white;
            border: 2px solid #fff !important;
        }

            .btn-tasfiya:hover {
                background: #fff !important;
                color: #4e57d4 !important;
                border: 2px solid #4e57d4 !important;
            }

        .rounded-2 {
            border-radius: 5px !important;
        }
    </style>
}

<div class="act-form-page py-3" dir="rtl">
    <div class="container-fluid px-1">
        <div class="card shadow act-form-card">

            <!-- HEADER -->
            <div class="act-form-header">
                <div class="act-form-header-left">
                    <div class="act-form-header-icon">
                        <i class="bi bi-bar-chart-line-fill"></i>
                    </div>
                    <div>
                        <p class="act-form-header-title">حصيلة نشاطات الإتصال</p>
                        <p class="act-form-header-sub">الوكالات الولائية حسب الفترة الزمنية</p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">

                <!-- FILTER -->
                <form method="get" class="row mb-3 align-items-end g-2">
                    <div class="col-md-3">
                        <label class="form-label text-muted" style="font-size:.8rem;font-weight:600;">
                            من تاريخ
                        </label>
                        <input type="date"
                               name="dateDebut"
                               class="form-control rounded-2"
                               value="@(Model.DateDebut.HasValue? Model.DateDebut.Value.ToString("yyyy-MM-dd") : "")" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label text-muted" style="font-size:.8rem;font-weight:600;">
                            إلى تاريخ
                        </label>
                        <input type="date"
                               name="dateFin"
                               class="form-control rounded-2"
                               value="@(Model.DateFin.HasValue? Model.DateFin.Value.ToString("yyyy-MM-dd") : "")" />
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100 rounded-2 btn-tasfiya">
                            <i class="bi bi-funnel-fill me-1"></i> تصفية
                        </button>
                    </div>

                    @if (Model.DateDebut.HasValue || Model.DateFin.HasValue)
                    {
                        <div class="col-md-3 d-flex align-items-end">
                            <a href="@Url.Action("Index", "Dashboard")"
                               class="btn w-100 rounded-2"
                               style="background:#f0f2ff;color:#4e57d4;border:1.5px solid #4e57d4;font-weight:600;">
                                <i class="bi bi-x-circle me-1"></i> إلغاء التصفية
                            </a>
                        </div>
                    }
                </form>

                <p class="act-section-divider">النتائج</p>

                <!-- ✅ TABLE : tfoot INSIDE table, BEFORE closing </div> -->
                <div class="table-responsive">
                    <table id="dashboardTable" class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>الولاية</th>
                                <th>الهيئة</th>
                                <th>أيام إعلامية وأبواب مفتوحة</th>
                                <th>معارض وصالونات</th>
                                <th>أيام دراسية وملتقيات Forum</th>
                                <th>جلسات تنسيقية خارجية/إتفاقيات</th>
                                <th>تغطيات إذاعية</th>
                                <th>تغطيات تلفزيونية</th>
                                <th>صحافة مكتوبة/إلكترونية</th>
                                <th>المجموع</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Data)
                            {
                                <tr class="@(item.Total == 0 ? "table-secondary" : "")">
                                    <td>
                                        @{
                                            int code;
                                            if (int.TryParse(item.StructureCode, out code) && code >= 161 && code <= 164)
                                            {
                                                @("160" + (code - 160))
                                            }
                                            else
                                            {
                                                @item.StructureCode
                                            }
                                        }
                                    </td>
                                    <td>@item.StructureDesignation</td>
                                    <td>@item.JourneeInfoCount</td>
                                    <td>@item.SalonCount</td>
                                    <td>@item.ForumCount</td>
                                    <td>@item.ReunionCount</td>
                                    <td>@item.RadioCount</td>
                                    <td>@item.TVCount</td>
                                    <td>@item.PresseCount</td>
                                    <td class="fw-bold">@item.Total</td>
                                </tr>
                            }
                        </tbody>

                        <!-- ✅ tfoot INSIDE <table>, BEFORE </table> -->
                        <tfoot class="table-dark">
                            <tr>
                                <th colspan="2">الإجمالي</th>
                                <th>@Model.Data.Sum(x => x.JourneeInfoCount)</th>
                                <th>@Model.Data.Sum(x => x.SalonCount)</th>
                                <th>@Model.Data.Sum(x => x.ForumCount)</th>
                                <th>@Model.Data.Sum(x => x.ReunionCount)</th>
                                <th>@Model.Data.Sum(x => x.RadioCount)</th>
                                <th>@Model.Data.Sum(x => x.TVCount)</th>
                                <th>@Model.Data.Sum(x => x.PresseCount)</th>
                                <th>@Model.Data.Sum(x => x.Total)</th>
                            </tr>
                        </tfoot>

                    </table>
                </div>
                <!-- ✅ </div> fermé APRÈS </table> -->

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_datatables.script" />
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <script>
        $(document).ready(function () {

            // ✅ Variables dateDebut / dateFin (plus de mois/annee)
            var dateDebut = '@(Model.DateDebut.HasValue? Model.DateDebut.Value.ToString("yyyy-MM-dd") : "")';
            var dateFin   = '@(Model.DateFin.HasValue? Model.DateFin.Value.ToString("yyyy-MM-dd")   : "")';

            var titreExcel = 'حصيلة نشاطات الإتصال';
            if (dateDebut || dateFin) {
                titreExcel += ' - من ' + (dateDebut || '...') + ' إلى ' + (dateFin || '...');
            }

            // ✅ Nom du fichier Excel
            var filename = 'حصيلة نشاطات الإتصال_'
                         + (dateDebut || 'بداية') + '_إلى_' + (dateFin || 'نهاية');

            $('#dashboardTable').DataTable({
                dom: 'Blfrtip',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: 'تصدير إلى Excel',
                        title: null,
                        messageTop: titreExcel,
                        className: 'btn-excel-custom',
                        filename: filename,
                        exportOptions: { columns: ':visible' }
                    }
                ],
                language: {
                    sProcessing:   "جارٍ المعالجة...",
                    sSearch:       "بحث:",
                    sLengthMenu:   "عرض _MENU_ عنصر",
                    sInfo:         "عرض _START_ إلى _END_ من أصل _TOTAL_ عنصر",
                    sInfoEmpty:    "عرض 0 إلى 0 من أصل 0 عنصر",
                    sInfoFiltered: "(تم التصفية من أصل _MAX_ عنصر)",
                    sZeroRecords:  "لم يتم العثور على عناصر مطابقة",
                    sEmptyTable:   "لا توجد بيانات متاحة في الجدول",
                    oPaginate: {
                        sFirst:    "الأول",
                        sPrevious: "السابق",
                        sNext:     "التالي",
                        sLast:     "الأخير"
                    }
                }
            });
        });
    </script>
}