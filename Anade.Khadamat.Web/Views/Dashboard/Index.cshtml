 


@model Anade.Khadamat.Web.ViewModels.DashboardFilterVM

@{
    ViewData["Title"] = "Dashboard Activités";
    ViewData["FullWidth"] = true;
}

@section head {
    <partial name="_datatables.style" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css">


    <style>
    .search-header {
        transition: all 0.3s ease;
        border: 1px solid #f0f0f0 !important;
    }

    .custom-input {
        background-color: #f8f9fa;
        font-size: 0.95rem;
    }

    .custom-input:focus {
        background-color: #fff;
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1) !important;
    }

   
    /* Support RTL pour les icônes si nécessaire */
    [dir="rtl"] .me-2 { margin-left: 0.5rem !important; margin-right: 0 !important; }
</style>



}

<div class="af-page" dir="rtl">

    <!-- HEADER — même structure que ActiviteJourneeInfo -->
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-bar-chart-line-fill"></i>
            </div>
            <div>
                <h1 class="af-header-title">حصيلة نشاطات الإتصال</h1>
                <p class="af-header-sub">الوكالات الولائية حسب الفترة الزمنية</p>
                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">حصيلة نشاطات الإتصال</span>
                </nav>
            </div>
        </div>
    </div>

    <div class=" ">
        <div class="af-card">
            <div class="card-body p-4">

   <div class="search-header bg-white p-4 rounded-4 shadow-sm border-0 mb-4">


    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-4 col-lg-3">
            <label class="form-label small fw-bold text-uppercase text-muted mb-1">
                <i class="bi bi-calendar-event me-1"></i> من تاريخ
            </label>
            <input type="date"
                   name="dateDebut"
                   class="form-control form-control-lg border-light-subtle rounded-3 shadow-none custom-input"
                   value="@(Model.DateDebut.HasValue ? Model.DateDebut.Value.ToString("yyyy-MM-dd") : "")" />
        </div>

        <div class="col-md-4 col-lg-3">
            <label class="form-label small fw-bold text-uppercase text-muted mb-1">
                <i class="bi bi-calendar-check me-1"></i> إلى تاريخ
            </label>
            <input type="date"
                   name="dateFin"
                   class="form-control form-control-lg border-light-subtle rounded-3 shadow-none custom-input"
                   value="@(Model.DateFin.HasValue ? Model.DateFin.Value.ToString("yyyy-MM-dd") : "")" />
        </div>

        <div class="col-md-4 col-lg-6 d-flex gap-2 justify-content-start">
            <button type="submit" class="btn btn-primary btn-lg px-4 rounded-3 shadow-sm d-flex align-items-center">
                <i class="bi bi-funnel-fill me-2"></i> تصفية
            </button>

            @if (Model.DateDebut.HasValue || Model.DateFin.HasValue)
            {
                <a href="@Url.Action("Index", "Dashboard")"
                   class="btn btn-outline-danger btn-lg px-4 rounded-3 d-flex align-items-center">
                    <i class="bi bi-x-lg me-2"></i> إلغاء
                </a>
            }
        </div>
    </form>
</div>

                <!-- Section title — même style af-section-wrap -->
                <div class="af-section-wrap">
                    <div class="py-2">
                        <span class="text-primary fw-medium" style="font-size:.75rem;letter-spacing:.8px;">
                            <i class="bi bi-list-ul me-1"></i>
                        </span>
                        <span class="af-section-title">النتائج</span>
                    </div>
                </div>

                <!-- TABLE -->
                <div class="table">
                    <table id="dashboardTable" class="table table-hover table-bordered tableDashboard align-middle w-100">
                        <thead>
                            <tr>
                                <th>الولاية</th>
                                <th>الهيئة</th>
                                <th>أيام إعلامية وأبواب مفتوحة</th>
                                <th>معارض وصالونات</th>
                                <th>أيام دراسية وملتقيات Forum</th>
                                <th>جلسات تنسيقية خارجية/إتفاقيات</th>
                                <th>تغطيات إذاعية</th>
                                <th>تغطيات تلفزيونية</th>
                                <th>صحافة مكتوبة/إلكترونية</th>
                                <th>المجموع</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Data)
                            {
                                <tr class="@(item.Total == 0 ? "table-secondary" : "")">
                                    <td>
                                        @{
                                            int code;
                                            if (int.TryParse(item.StructureCode, out code) && code >= 161 && code <= 164)
                                            {
                                                @("160" + (code - 160))
                                            }
                                            else
                                            {
                                                @item.StructureCode
                                            }
                                        }
                                    </td>
                                    <td><span class="fw-medium">@item.StructureDesignation</span></td>
                                    <td>@item.JourneeInfoCount</td>
                                    <td>@item.SalonCount</td>
                                    <td>@item.ForumCount</td>
                                    <td>@item.ReunionCount</td>
                                    <td>@item.RadioCount</td>
                                    <td>@item.TVCount</td>
                                    <td>@item.PresseCount</td>
                                    <td class="fw-bold">@item.Total</td>
                                </tr>
                            }
                        </tbody>

                        <tfoot class="table-dark">
                            <tr>
                                <th colspan="2">الإجمالي</th>
                                <th>@Model.Data.Sum(x => x.JourneeInfoCount)</th>
                                <th>@Model.Data.Sum(x => x.SalonCount)</th>
                                <th>@Model.Data.Sum(x => x.ForumCount)</th>
                                <th>@Model.Data.Sum(x => x.ReunionCount)</th>
                                <th>@Model.Data.Sum(x => x.RadioCount)</th>
                                <th>@Model.Data.Sum(x => x.TVCount)</th>
                                <th>@Model.Data.Sum(x => x.PresseCount)</th>
                                <th>@Model.Data.Sum(x => x.Total)</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_datatables.script" />
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <script>
        $(document).ready(function () {

            var dateDebut = '@(Model.DateDebut.HasValue? Model.DateDebut.Value.ToString("yyyy-MM-dd") : "")';
            var dateFin   = '@(Model.DateFin.HasValue? Model.DateFin.Value.ToString("yyyy-MM-dd")   : "")';

            var titreExcel = 'حصيلة نشاطات الإتصال';
            if (dateDebut || dateFin) {
                titreExcel += ' - من ' + (dateDebut || '...') + ' إلى ' + (dateFin || '...');
            }

            var filename = 'حصيلة نشاطات الإتصال_'
                         + (dateDebut || 'بداية') + '_إلى_' + (dateFin || 'نهاية');

            $('#dashboardTable').DataTable({
                dom: 'Blfrtip',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: '<i class="bi bi-file-earmark-excel-fill me-1"></i> تصدير Excel',
                        title: null,
                        messageTop: titreExcel,
                        className: 'btn btn-success btn-sm',
                        filename: filename,
                        exportOptions: { columns: ':visible' }
                    }
                ],
                language: {
                    sProcessing:   "جارٍ المعالجة...",
                    sSearch:       "بحث:",
                    sLengthMenu:   "عرض _MENU_ عنصر",
                    sInfo:         "عرض _START_ إلى _END_ من أصل _TOTAL_ عنصر",
                    sInfoEmpty:    "عرض 0 إلى 0 من أصل 0 عنصر",
                    sInfoFiltered: "(تم التصفية من أصل _MAX_ عنصر)",
                    sZeroRecords:  "لم يتم العثور على عناصر مطابقة",
                    sEmptyTable:   "لا توجد بيانات متاحة في الجدول",
                    oPaginate: {
                        sFirst:    "الأول",
                        sPrevious: "السابق",
                        sNext:     "التالي",
                        sLast:     "الأخير"
                    }
                }
            });
        });
    </script>
}