@model IEnumerable<Anade.Khadamat.Domain.Entity.ActiviteRadio>

@{
    ViewData["Title"] = "التغطيات الإذاعية";
    ViewData["FullWidth"] = true;
}

@section head {
    <partial name="_datatables.style" />
}

<style>
    .act-form-page {
        background: linear-gradient(160deg,#eef2ff 0%,#f8f9fa 60%);
        min-height: calc(100vh - 64px);
    }

    .act-form-card {
        border-radius: 18px;
        overflow: hidden;
        border: none;
    }

    .act-form-header {
        background: linear-gradient(135deg,#4e57d4 0%,#6a76ef 100%);
        padding: 1.75rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .act-form-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .act-form-header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255,255,255,.18);
        border-radius: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        color: #fff;
        flex-shrink: 0;
    }

    .act-form-header-title {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
        line-height: 1.25;
    }

    .act-form-header-sub {
        color: rgba(255,255,255,.68);
        font-size: .78rem;
        margin: .15rem 0 0;
    }

    .btn-add {
        background: rgba(255,255,255,.2);
        border: 1.5px solid rgba(255,255,255,.45);
        border-radius: 10px;
        color: #fff;
        padding: .5rem 1.25rem;
        font-weight: 600;
        font-size: .85rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        transition: background .2s;
        text-decoration: none;
    }

        .btn-add:hover {
            background: rgba(255,255,255,.32);
            color: #fff;
        }

    .act-section-divider {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .9px;
        color: #9099b5;
        padding-bottom: .45rem;
        border-bottom: 1.5px solid #eaecf4;
        margin: 0 0 1.1rem;
    }

    .dt-buttons {
        margin-bottom: 10px;
    }

    #myTable {
        table-layout: fixed;
        width: 100%;
    }

        #myTable thead th {
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: .4px;
            color: #fff;
            background-color: #4e57d4;
            border-color: #5d67dc;
            max-width: 50px;
        }

        #myTable tbody tr {
            font-size: 1.2rem;
        }

            #myTable tbody tr:hover {
                background: #f0f2ff;
            }

    .btn-action {
        border-radius: 8px;
        padding: .3rem .6rem;
        font-size: 1.2rem;
    }

    .m-custom-100 {
        margin-inline: 100px !important;
    }
</style>
 

<div class="act-form-page py-2 m-custom-100" dir="rtl">
    <div class="container-fluid px-1">

        <div class="card shadow act-form-card">

            <!-- HEADER -->
            <div class="act-form-header">
                <div class="act-form-header-left">
                    <div class="act-form-header-icon">
                        <i class="bi bi-broadcast"></i>
                    </div>
                    <div>
                        <p class="act-form-header-title">التغطيات الإذاعية</p>
                        <p class="act-form-header-sub">قائمة جميع الحصص والتدخلات الإذاعية</p>
                    </div>
                </div>

                <a asp-controller="ActiviteRadio" asp-action="Create" class="btn-add">
                    <i class="bi bi-plus-circle"></i> إضافة
                </a>
            </div>

            <!-- BODY -->
            <div class="card-body p-4">
                <partial name="_Message" />

                <p class="act-section-divider">قائمة التغطيات</p>

                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle table-bordered" id="myTable">
                        <thead>
                            <tr>
                                <th>Id</th>.
                                <th>الهيئة</th>
                                <th>المحطة الإذاعية</th>
                                <th>الموضوع</th>
                                <th>المتدخلون</th>
                          
                                <th>التاريخ</th>
                                <th>إجراءات</th>
                            </tr>
                        </thead>
                        <tbody class="table-group-divider"></tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_datatables.script" />
    <script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $('#myTable').DataTable({
                processing: true,
                serverSide: true,
                order: [[0, "desc"]],
                lengthMenu: [[10, 20, 50, 9999], [10, 20, 50, "الكل"]],
                ajax: {
                    url: "/ActiviteRadio/RadioDataTable",
                    type: "POST"
                },
                columns: [
                    { data: "id", visible: false },
                    { data: "activite.agenceWilaya.designationAr" },
                    { data: "stationRadio" },
                    { data: "activite.sujet" },
                    { data: "intervenants" },
                 
                    {
                        data: "activite.dateActivite",
                        render: function (data) {
                            return moment(data).format('DD/MM/YYYY');
                        }
                    },
                    {
                        data: "id",
                        render: function (data, type, row) {
                            return `
                                <div class="d-flex gap-2">
                                    <a href="/ActiviteRadio/Details/${row.id}" class="btn btn-outline-info btn-action" title="تفاصيل">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <a href="/ActiviteRadio/Edit/${row.id}" class="btn btn-outline-secondary btn-action" title="تعديل">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/ActiviteRadio/Delete/${row.id}" class="btn btn-outline-danger btn-action" title="حذف">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            `;
                        }
                    }
                ],
                language: {
                    sProcessing: "جارٍ المعالجة...",
                    sSearch: "بحث:",
                    sLengthMenu: "عرض _MENU_ عنصر",
                    sInfo: "عرض _START_ إلى _END_ من أصل _TOTAL_",
                    sZeroRecords: "لا توجد نتائج",
                    oPaginate: {
                        sNext: "التالي",
                        sPrevious: "السابق"
                    }
                },
                dom: 'Blfrtip',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: 'تصدير Excel',
                        title: ' قائمة_التغطيات_الاذاعية ',
                        className: 'btn btn-success btn-sm',
                        exportOptions: { columns: [1, 2, 3, 4] }
                    }
                ]
            });
        });
    </script>
}