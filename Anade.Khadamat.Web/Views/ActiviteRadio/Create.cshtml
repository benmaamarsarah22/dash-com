@model Anade.Khadamat.Web.ViewModels.ActiviteRadioVM

@{
    ViewData["Title"] = "إضافة تغطية إذاعية";
    ViewData["FullWidth"] = true;
}

<div class="af-page" dir="rtl">

    <!-- HEADER -->
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-broadcast"></i>
            </div>
            <div>
                <h1 class="af-header-title">التغطيات الإذاعية</h1>
                <p class="af-header-sub">إضافة تغطية إذاعية جديدة</p>
                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <a asp-controller="ActiviteRadio" asp-action="Index">التغطيات الإذاعية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">إضافة تغطية</span>
                </nav>
            </div>
        </div>
    </div>

    <!-- BODY -->
    <div class="container-fluid px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">

                <partial name="_Message" />

                <div class="card af-card shadow-sm mb-5">
                    <div class="card-body p-4 p-md-5">

                        <!-- TITLE -->
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="af-stat-icon shadow-sm" style="background: var(--light);">
                                <i class="bi bi-plus-circle-fill text-primary"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0" style="color: var(--dark);">معلومات التغطية</h4>
                                <p class="text-muted small mb-0">يرجى إدخال بيانات التغطية الإذاعية بدقة</p>
                            </div>
                        </div>

                        <form asp-action="Create" method="post">
                            @Html.AntiForgeryToken()

                            <!-- SECTION -->
                            <div class="mb-4">
                                <span class="af-section-title">البيانات الأساسية</span>
                            </div>

                            <!-- STATION -->
                            <div class="mb-3">
                                <label asp-for="StationRadio" class="form-label fw-bold small">المحطة الإذاعية</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-start-0">
                                        <i class="bi bi-broadcast"></i>
                                    </span>
                                    <input asp-for="StationRadio" class="form-control af-form-input" placeholder="اسم المحطة الإذاعية" />
                                </div>
                                <span asp-validation-for="StationRadio" class="text-danger small"></span>
                            </div>

                            <!-- SUJET -->
                            <div class="mb-3">
                                <label asp-for="Sujet" class="form-label fw-bold small">الموضوع</label>
                                <input asp-for="Sujet" class="form-control af-form-input" placeholder="موضوع التغطية..." />
                                <span asp-validation-for="Sujet" class="text-danger small"></span>
                            </div>

                            <!-- DATE -->
                            <div class="mb-4">
                                <label asp-for="DateActivite" class="form-label fw-bold small">تاريخ التغطية</label>
                                <input asp-for="DateActivite" type="date" class="form-control af-form-input" />
                                <span asp-validation-for="DateActivite" class="text-danger small"></span>
                            </div>

                            <!-- INTERVENANTS -->
                            <div class="mb-5">
                                <label asp-for="Intervenants" class="form-label fw-bold small">المتدخلين</label>
                                <textarea asp-for="Intervenants" class="form-control af-form-input" rows="3"
                                          placeholder="أسماء المتدخلين..."></textarea>
                                <span asp-validation-for="Intervenants" class="text-danger small"></span>
                            </div>

                            <hr class="opacity-10 mb-4">

                            <!-- ACTIONS -->
                            <div class="d-flex gap-3 justify-content-end">
                                <a asp-action="Index" class="btn btn-light px-4 fw-bold">
                                    <i class="bi bi-x-circle me-1"></i> إلغاء
                                </a>
                                <button type="submit" class="btn btn-af-add px-5">
                                    <i class="bi bi-check-lg me-1"></i> حفظ التغطية
                                </button>
                            </div>

                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.querySelector('form');

            form.addEventListener('submit', function () {

                // vérifier validation
                if ($(form).valid()) {
                    const submitBtn = form.querySelector('button[type="submit"]');

                    // disable button
                    submitBtn.disabled = true;

                    // loading state
                    submitBtn.innerHTML = `
                        <span class="spinner-border spinner-border-sm"></span>
                        جاري الحفظ...
                    `;
                }
            });
        });
    </script>
}