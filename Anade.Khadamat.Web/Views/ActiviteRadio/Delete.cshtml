@model Anade.Khadamat.Domain.Entity.ActiviteRadio

@{
    ViewData["Title"] = "حذف تغطية إذاعية";
}

<style>
    .act-form-page {
        background: linear-gradient(160deg,#eef2ff 0%,#f8f9fa 60%);
        min-height: calc(100vh - 64px);
    }

    .act-form-card {
        border-radius: 18px;
        overflow: hidden;
        border: none;
    }

    .act-form-header {
        background: linear-gradient(135deg,#4e57d4 0%,#6a76ef 100%);
        padding: 1.75rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .act-form-header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255,255,255,.18);
        border-radius: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        color: #fff;
    }

    .act-form-header-title {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
    }

    .act-form-header-sub {
        color: rgba(255,255,255,.68);
        font-size: .78rem;
    }

    .act-section-divider {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .9px;
        color: #9099b5;
        padding-bottom: .45rem;
        border-bottom: 1.5px solid #eaecf4;
        margin: 1.5rem 0 1.1rem;
    }

    .act-info-row {
        margin-bottom: 1rem;
    }

    .act-info-label {
        font-size: .8rem;
        font-weight: 600;
        color: #4e5568;
        margin-bottom: .28rem;
        display: block;
    }

    .act-info-value {
        font-size: .875rem;
        color: #2d3148;
        background: #fafbff;
        border: 1px solid #dde1ef;
        border-radius: 10px;
        padding: .52rem .85rem;
        display: block;
    }

    .alert-delete {
        background: #fff5f5;
        border: 1px solid #fcd0cc;
        border-radius: 12px;
        color: #b03a2e;
        font-size: .85rem;
        font-weight: 600;
        padding: .75rem 1rem;
        margin-bottom: 1.2rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .btn-act-delete {
        background: linear-gradient(135deg,#e24b4a,#c03838);
        border: none;
        border-radius: 10px;
        color: #fff;
        padding: .58rem 2rem;
        font-weight: 600;
    }

    .btn-act-cancel {
        border-radius: 10px;
        padding: .58rem 1.4rem;
    }
</style>

<div class="act-form-page py-5" dir="rtl">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-9">

                <div class="card shadow act-form-card">

                    <!-- HEADER -->
                    <div class="act-form-header">
                        <div class="act-form-header-icon">
                            <i class="bi bi-broadcast"></i>
                        </div>
                        <div>
                            <p class="act-form-header-title">حذف تغطية إذاعية</p>
                            <p class="act-form-header-sub">نشاط إعلامي – إذاعة</p>
                        </div>
                    </div>

                    <div class="card-body p-4">

                        <!-- ALERT -->
                        <div class="alert-delete">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            هل أنت متأكد أنك تريد حذف هذه التغطية الإذاعية؟ لا يمكن التراجع عن هذا الإجراء.
                        </div>

                        <!-- INFO -->
                        <p class="act-section-divider">معلومات التغطية</p>

                        <div class="act-info-row">
                            <span class="act-info-label">المحطة الإذاعية</span>
                            <span class="act-info-value">@Model.StationRadio</span>
                        </div>

                        <div class="act-info-row">
                            <span class="act-info-label">الموضوع</span>
                            <span class="act-info-value">@Model.Activite?.Sujet</span>
                        </div>

                        <div class="act-info-row">
                            <span class="act-info-label">المتدخلون</span>
                            <span class="act-info-value">@Model.Intervenants</span>
                        </div>
 

                        <div class="act-info-row">
                            <span class="act-info-label">التاريخ</span>
                            <span class="act-info-value">
                                @Model.Activite?.DateActivite.ToString("dd/MM/yyyy")
                            </span>
                        </div>
                        <div class="act-info-row">
                            <span class="act-info-label"> الهيئة</span>
                            <span class="act-info-value">@Model.Activite.AgenceWilaya.DesignationAr</span>
                        </div>

                        <!-- ACTIONS -->
                        <form asp-action="DeleteConfirmed" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="d-flex gap-2 pt-2">
                                <button type="submit" class="btn btn-act-delete">
                                    <i class="bi bi-trash3 me-1"></i> حذف
                                </button>

                                <a asp-action="Index" class="btn btn-outline-secondary btn-act-cancel">
                                    إلغاء
                                </a>
                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>