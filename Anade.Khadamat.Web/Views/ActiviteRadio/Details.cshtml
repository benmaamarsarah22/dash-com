@model Anade.Khadamat.Domain.Entity.ActiviteRadio

@{
    ViewData["Title"] = "تفاصيل التغطية الإذاعية";
}

<style>
    .act-form-page { background: linear-gradient(160deg,#eef2ff 0%,#f8f9fa 60%); min-height: calc(100vh - 64px); }
    .act-form-card { border-radius: 18px; overflow: hidden; border: none; }
    .act-form-header { background: linear-gradient(135deg,#4e57d4 0%,#6a76ef 100%); padding: 1.75rem 2rem; display: flex; align-items: center; gap: 1rem; }
    .act-form-header-icon { width: 50px; height: 50px; background: rgba(255,255,255,.18); border-radius: 13px; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; color: #fff; flex-shrink: 0; }
    .act-form-header-title { color: #fff; font-size: 1.1rem; font-weight: 700; margin: 0; line-height: 1.25; }
    .act-form-header-sub  { color: rgba(255,255,255,.68); font-size: .78rem; margin: .15rem 0 0; }
    .act-section-divider { font-size: .68rem; font-weight: 700; letter-spacing: .9px; color: #9099b5; padding-bottom: .45rem; border-bottom: 1.5px solid #eaecf4; margin: 1.5rem 0 1.1rem; }
    .act-detail-tile { background: #f8f9ff; border: 1px solid #e8ebf6; border-radius: 12px; padding: 1rem 1.2rem; }
    .act-detail-tile .tile-label { font-size: .72rem; font-weight: 700; letter-spacing: .6px; color: #9099b5; margin-bottom: .3rem; }
    .act-detail-tile .tile-value { font-size: .9rem; color: #2c3050; font-weight: 500; }
    .btn-act-cancel { border-radius: 10px; font-size: .875rem; padding: .58rem 1.4rem; color: #6c757d; border-color: #d0d4df; }
    .btn-act-cancel:hover { background: #f4f5fa; color: #444; border-color: #bcc0ce; }
</style>

<div class="act-form-page py-5" dir="rtl">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-10">
                <div class="card shadow act-form-card">
                    <div class="act-form-header">
                        <div class="act-form-header-icon"><i class="bi bi-broadcast"></i></div>
                        <div>
                            <p class="act-form-header-title">تفاصيل التغطية الإذاعية</p>
                            <p class="act-form-header-sub">تغطيات إذاعية</p>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <p class="act-section-divider">معلومات التغطية</p>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="act-detail-tile">
                                    <div class="tile-label">المحطة الإذاعية</div>
                                    <div class="tile-value">@Model.StationRadio</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="act-detail-tile">
                                    <div class="tile-label">تاريخ البث</div>
                                    <div class="tile-value">@Model.Activite.DateActivite.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="act-detail-tile">
                                    <div class="tile-label">الموضوع</div>
                                    <div class="tile-value">@Model.Activite.Sujet</div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="act-detail-tile">
                                    <div class="tile-label">المتدخلون</div>
                                    <div class="tile-value">@Model.Intervenants</div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-act-cancel">رجوع</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mt-4" dir="rtl">

    <div class="card shadow border-0 rounded-4">

        <!-- Header -->
        <div class="card-header bg-primary text-white text-center rounded-top-4">
            <h4 class="mb-0">📄تفاصيل التغطية الإذاعية</h4>
        </div>

        <!-- Body -->
        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-6">
                    <div class="p-3 border rounded bg-light">
                        <strong>📌 موضوع  </strong>
                        <div>@Model.Activite.Sujet</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 border rounded bg-light">
                        <strong>📍 المحطة الإذاعية</strong>
                        <div>@Model.StationRadio</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 border rounded bg-light">
                        <strong>📅 التاريخ</strong>
                        <div>@Model.Activite.DateActivite.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>

                 

                <div class="col-md-6">
                    <div class="p-3 border rounded bg-light">
                        <strong>🙋 االمتدخلين</strong>
                        <div>@Model.Intervenants</div>
                    </div>
                </div>

               
                </div>

            </div>

            <!-- Button -->
            <div class="text-start mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    ⬅ رجوع
                </a>
            </div>

        </div>
    </div>

</div>