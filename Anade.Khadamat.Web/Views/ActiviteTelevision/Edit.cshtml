@model Anade.Khadamat.Web.ViewModels.ActiviteTelevisionVM

@{
    ViewData["Title"] = "تعديل التغطية التلفزيونية";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <partial name="_Message" />

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="mb-4 fw-700 text-primary">@ViewData["Title"]</h5>

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@ViewBag.TvId" />
                        <input type="hidden" name="activiteId" value="@ViewBag.ActiviteId" />

                        <div class="mb-3">
                            <label asp-for="ChaineTV" class="form-label fw-600">محطة البث</label>
                            <input asp-for="ChaineTV" class="form-control" />
                            <span asp-validation-for="ChaineTV" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Sujet" class="form-label fw-600">الموضوع</label>
                            <input asp-for="Sujet" class="form-control" />
                            <span asp-validation-for="Sujet" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DateActivite" class="form-label fw-600">التاريخ</label>
                            <input asp-for="DateActivite" type="date" class="form-control" />
                            <span asp-validation-for="DateActivite" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4">حفظ</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">إلغاء</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}