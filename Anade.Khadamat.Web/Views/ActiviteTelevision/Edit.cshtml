@model Anade.Khadamat.Web.ViewModels.ActiviteTelevisionVM

@{
    ViewData["Title"] = "تعديل التغطية التلفزيونية";
    ViewData["FullWidth"] = true;
}

<div class="af-page" dir="rtl">
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-pencil-square"></i>
            </div>
            <div>
                <h1 class="af-header-title">تعديل التغطية التلفزيونية</h1>
                <p class="af-header-sub">تحديث بيانات التغطية المسجلة في النظام</p>
                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <a asp-controller="ActiviteTelevision" asp-action="Index">التغطيات التلفزيونية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">تعديل البيانات</span>
                </nav>
            </div>
        </div>
    </div>

    <div class="container-fluid px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">

                <partial name="_Message" />

                <div class="card af-card shadow-sm mb-5">
                    <div class="card-body p-4 p-md-5">

                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="af-stat-icon shadow-sm" style="background: var(--light);">
                                <i class="bi bi-pencil-fill text-primary"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0" style="color: var(--dark);">تحديث معلومات التغطية</h4>
                                <p class="text-muted small mb-0">يرجى تعديل البيانات المطلوبة والضغط على حفظ</p>
                            </div>
                        </div>

                        <form asp-action="Edit" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@ViewBag.TvId" />
                            <input type="hidden" name="activiteId" value="@ViewBag.ActiviteId" />

                            <div class="mb-4">
                                <span class="af-section-title">معلومات التغطية</span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ChaineTV" class="form-label fw-bold small">القناة التلفزيونية</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-start-0">
                                        <i class="bi bi-tv"></i>
                                    </span>
                                    <input asp-for="ChaineTV" class="form-control af-form-input" placeholder="اسم القناة التلفزيونية" />
                                </div>
                                <span asp-validation-for="ChaineTV" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Sujet" class="form-label fw-bold small">الموضوع</label>
                                <input asp-for="Sujet" class="form-control af-form-input" placeholder="أدخل موضوع التغطية..." />
                                <span asp-validation-for="Sujet" class="text-danger small"></span>
                            </div>

                            <div class="mb-5">
                                <label asp-for="DateActivite" class="form-label fw-bold small">تاريخ البث</label>
                                <input asp-for="DateActivite" type="date" class="form-control af-form-input" />
                                <span asp-validation-for="DateActivite" class="text-danger small"></span>
                            </div>

                            <hr class="opacity-10 mb-4">

                            <div class="d-flex gap-3 justify-content-end">
                                <a asp-action="Index" class="btn btn-light px-4 fw-bold">
                                    <i class="bi bi-x-circle me-1"></i> إلغاء
                                </a>
                                <button type="submit" class="btn btn-primary px-5 fw-bold" style="background-color: var(--primary); border: none;">
                                    <i class="bi bi-save me-1"></i> حفظ التغييرات
                                </button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.querySelector('form');

            form.addEventListener('submit', function (e) {
                if ($(form).valid()) {
                    const submitBtn = form.querySelector('button[type="submit"]');
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = `
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        جاري الحفظ...
                    `;
                }
            });
        });
    </script>
}