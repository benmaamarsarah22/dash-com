@model Anade.Khadamat.Domain.Entity.ActiviteJourneeInfo

@{
    ViewData["Title"] = "حذف يوم إعلامي";
}

<style>
    .act-form-page {
        background: linear-gradient(160deg,#eef2ff 0%,#f8f9fa 60%);
        min-height: calc(100vh - 64px);
    }

    .act-form-card {
        border-radius: 18px;
        overflow: hidden;
        border: none;
    }

    .act-form-header {
        background: linear-gradient(135deg,#4e57d4 0%,#6a76ef 100%);
        padding: 1.75rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .act-form-header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255,255,255,.18);
        border-radius: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        color: #fff;
        flex-shrink: 0;
    }

    .act-form-header-title {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
        line-height: 1.25;
    }

    .act-form-header-sub {
        color: rgba(255,255,255,.68);
        font-size: .78rem;
        margin: .15rem 0 0;
    }

    .act-section-divider {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .9px;
        color: #9099b5;
        padding-bottom: .45rem;
        border-bottom: 1.5px solid #eaecf4;
        margin: 1.5rem 0 1.1rem;
    }

    .act-info-row {
        display: flex;
        flex-direction: column;
        margin-bottom: 1rem;
    }

    .act-info-label {
        font-size: .8rem;
        font-weight: 600;
        color: #4e5568;
        margin-bottom: .28rem;
    }

    .act-info-value {
        font-size: .875rem;
        color: #2d3148;
        background: #fafbff;
        border: 1px solid #dde1ef;
        border-radius: 10px;
        padding: .52rem .85rem;
    }

    .alert-delete {
        background: #fff5f5;
        border: 1px solid #fcd0cc;
        border-radius: 12px;
        color: #b03a2e;
        font-size: .85rem;
        font-weight: 600;
        padding: .75rem 1rem;
        margin-bottom: 1.2rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .btn-act-delete {
        background: linear-gradient(135deg,#e24b4a,#c03838);
        border: none;
        border-radius: 10px;
        color: #fff;
        padding: .58rem 2rem;
        font-weight: 600;
        font-size: .875rem;
        transition: opacity .2s, transform .15s;
    }

        .btn-act-delete:hover {
            opacity: .88;
            transform: translateY(-1px);
            color: #fff;
        }

    .btn-act-cancel {
        border-radius: 10px;
        font-size: .875rem;
        padding: .58rem 1.4rem;
        color: #6c757d;
        border-color: #d0d4df;
    }

        .btn-act-cancel:hover {
            background: #f4f5fa;
            color: #444;
            border-color: #bcc0ce;
        }
</style>
 

<div class="act-form-page py-5" dir="rtl">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-9">
                <partial name="_Message" />
                <div class="card shadow act-form-card">
                    <div class="act-form-header">
                        <div class="act-form-header-icon"><i class="bi bi-trash3"></i></div>
                        <div>
                            <p class="act-form-header-title">حذف يوم إعلامي</p>
                            <p class="act-form-header-sub">أيام إعلامية وأبواب مفتوحة</p>
                        </div>
                    </div>
                    <div class="card-body p-4">

                        <div class="alert-delete">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            هل أنت متأكد أنك تريد حذف هذا اليوم الإعلامي؟ لا يمكن التراجع عن هذا الإجراء.
                        </div>

                        <p class="act-section-divider">معلومات النشاط</p>

                        <div class="act-info-row">
                            <span class="act-info-label">الموضوع</span>
                            <span class="act-info-value">@Model.Activite?.Sujet</span>
                        </div>
                        <div class="act-info-row">
                            <span class="act-info-label">المكان</span>
                            <span class="act-info-value">@Model.Activite?.Lieu</span>
                        </div>
                        <div class="row g-3 mb-1">
                            <div class="col-md-6">
                                <div class="act-info-row">
                                    <span class="act-info-label">تاريخ النشاط</span>
                                    <span class="act-info-value">@Model.Activite?.DateActivite.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="act-info-row">
                                    <span class="act-info-label">عدد المشاركين</span>
                                    <span class="act-info-value">@Model.Activite?.NombreVisiteurs</span>
                                </div>
                            </div>
                        </div>

                        <p class="act-section-divider">المنظمون والمشاركون</p>

                        <div class="act-info-row">
                            <span class="act-info-label">المنظمون</span>
                            <span class="act-info-value">@Model.Activite?.Organisateurs</span>
                        </div>
                        <div class="act-info-row">
                            <span class="act-info-label">المشاركون</span>
                            <span class="act-info-value">@Model.Activite?.Participants</span>
                        </div>

                        <form asp-action="DeleteConfirmed" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="d-flex gap-2 pt-2">
                                <button type="submit" class="btn btn-act-delete">
                                    <i class="bi bi-trash3 me-1"></i> حذف
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-act-cancel">إلغاء</a>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>