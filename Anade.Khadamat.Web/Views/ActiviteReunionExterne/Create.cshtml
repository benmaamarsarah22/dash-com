@model Anade.Khadamat.Web.ViewModels.ActiviteReunionExterneVM

@{
    ViewData["Title"] = "جلسات تنسيقية خارجية -إتفاقيات  جديدة";
}
<h2>@ViewData["Title"]</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Sujet" class="form-label"></label>
        <input asp-for="Sujet" class="form-control" />
        <span asp-validation-for="Sujet" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Lieu" class="form-label"></label>
        <input asp-for="Lieu" class="form-control" />
        <span asp-validation-for="Lieu" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Organisateurs" class="form-label"></label>
        <input asp-for="Organisateurs" class="form-control" />
        <span asp-validation-for="Organisateurs" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Participants" class="form-label"></label>
        <input asp-for="Participants" class="form-control" />
        <span asp-validation-for="Participants" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DateActivite" class="form-label"></label>
        <input asp-for="DateActivite" type="date" class="form-control" />
        <span asp-validation-for="DateActivite" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">إنشاء</button>
    <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}