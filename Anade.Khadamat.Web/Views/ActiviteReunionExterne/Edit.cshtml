@model Anade.Khadamat.Web.ViewModels.ActiviteReunionExterneVM

@{
    ViewData["Title"] = "تعديل الجلسة التنسيقية";
    ViewData["FullWidth"] = true;
}

<div class="af-page" dir="rtl">

    <!-- HEADER -->
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-pencil-square"></i>
            </div>
            <div>
                <h1 class="af-header-title">تعديل الجلسة التنسيقية الخارجية / اتفاقية</h1>
                <p class="af-header-sub">تحديث بيانات الجلسة</p>

                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <a asp-action="Index">الجلسات التنسيقية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">تعديل البيانات</span>
                </nav>
            </div>
        </div>
    </div>

    <!-- BODY -->
    <div class="container-fluid px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">

                <partial name="_Message" />

                <div class="card af-card shadow-sm mb-5">
                    <div class="card-body p-4 p-md-5">

                        <!-- TITLE -->
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="af-stat-icon shadow-sm" style="background: var(--light);">
                                <i class="bi bi-pencil-fill text-primary"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0" style="color: var(--dark);">تحديث معلومات الجلسة</h4>
                                <p class="text-muted small mb-0">قم بتعديل البيانات ثم اضغط حفظ</p>
                            </div>
                        </div>

                        <form asp-action="Edit" method="post">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@ViewBag.JourneeId" />
                            <input type="hidden" name="activiteId" value="@ViewBag.ActiviteId" />

                            <!-- SECTION -->
                            <div class="mb-4">
                                <span class="af-section-title">معلومات الجلسة</span>
                            </div>

                            <!-- SUJET -->
                            <div class="mb-3">
                                <label asp-for="Sujet" class="form-label fw-bold small">الموضوع</label>
                                <input asp-for="Sujet" class="form-control af-form-input" placeholder="موضوع الجلسة..." />
                                <span asp-validation-for="Sujet" class="text-danger small"></span>
                            </div>

                            <!-- LIEU -->
                            <div class="mb-3">
                                <label asp-for="Lieu" class="form-label fw-bold small">المكان</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-start-0">
                                        <i class="bi bi-geo-alt"></i>
                                    </span>
                                    <input asp-for="Lieu" class="form-control af-form-input" placeholder="مكان الانعقاد" />
                                </div>
                                <span asp-validation-for="Lieu" class="text-danger small"></span>
                            </div>

                            <!-- DATE -->
                            <div class="mb-4">
                                <label asp-for="DateActivite" class="form-label fw-bold small">تاريخ الجلسة</label>
                                <input asp-for="DateActivite" type="date" class="form-control af-form-input" />
                                <span asp-validation-for="DateActivite" class="text-danger small"></span>
                            </div>

                            <!-- SECTION 2 -->
                            <div class="mb-4 mt-4">
                                <span class="af-section-title">المنظمون والمشاركون</span>
                            </div>

                            <!-- ORGANISATEURS -->
                            <div class="mb-3">
                                <label asp-for="Organisateurs" class="form-label fw-bold small">المنظمون</label>
                                <input asp-for="Organisateurs" class="form-control af-form-input" placeholder="جهات التنظيم..." />
                                <span asp-validation-for="Organisateurs" class="text-danger small"></span>
                            </div>

                            <!-- PARTICIPANTS -->
                            <div class="mb-5">
                                <label asp-for="Participants" class="form-label fw-bold small">المشاركون</label>
                                <textarea asp-for="Participants"
                                          class="form-control af-form-input"
                                          rows="3"
                                          placeholder="المشاركون والممثلون..."></textarea>
                                <span asp-validation-for="Participants" class="text-danger small"></span>
                            </div>

                            <hr class="opacity-10 mb-4">

                            <!-- ACTIONS -->
                            <div class="d-flex gap-3 justify-content-end">
                                <a asp-action="Index" class="btn btn-light px-4 fw-bold">
                                    <i class="bi bi-x-circle me-1"></i> إلغاء
                                </a>

                                <button type="submit"
                                        class="btn btn-primary px-5 fw-bold"
                                        style="background-color: var(--primary); border: none;">
                                    <i class="bi bi-save me-1"></i> حفظ التغييرات
                                </button>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.querySelector('form');

            form.addEventListener('submit', function () {
                if ($(form).valid()) {
                    const submitBtn = form.querySelector('button[type="submit"]');

                    submitBtn.disabled = true;

                    submitBtn.innerHTML = `
                        <span class="spinner-border spinner-border-sm"></span>
                        جاري الحفظ...
                    `;
                }
            });
        });
    </script>
}