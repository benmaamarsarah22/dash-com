@model CreateRoleViewModel

@{ ViewBag.Title = "Creer un nouveau Role"; }


<!-- Header Start -->

<div class="container-fluid bg-primary py-2 mb-5 page-header">
    <div class="container py-2">
        <div class="row justify-content-center">
            <div class="col-lg-10 text-center">
                <h1 class="display-6 text-white animated slideInDown">@ViewData["Title"]</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-center">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white">Home</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Administration" asp-action="ListRoles" class="text-white">Liste des roles</a></li>
                        <li class="breadcrumb-item text-white active" aria-current="page">@ViewData["Title"]</li>
                    </ol>
                </nav>

            </div>
        </div>
    </div>
</div>
<partial name="_Message" />
<!-- Header End -->








        <div class="container">

            <form asp-action="CreateRole" method="post" class="mt-5">
                <div asp-validation-summary="All" class="text-danger">
                </div>
                <div class="form-group row">
                    <label asp-for="RoleName" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <input asp-for="RoleName" class="form-control" placeholder="Name">
                        <span asp-validation-for="RoleName" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-sm-10">
                        <button type="submit" class="btn btn-primary btn-style mt-4" style="width:auto">
                            Create Role
                        </button>
                        <a asp-action="ListRoles" class="btn btn-link btn-style mt-4">Annulé</a>

                    </div>
                </div>
            </form>


        </div>











