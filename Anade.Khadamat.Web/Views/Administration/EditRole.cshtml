@model EditRoleViewModel

@{ ViewBag.Title = "Edit Role"; }

<!-- Header Start -->

<div class="container-fluid bg-primary py-2 mb-5 page-header">
    <div class="container py-2">
        <div class="row justify-content-center">
            <div class="col-lg-10 text-center">
                <h1 class="display-6 text-white animated slideInDown">@ViewData["Title"]</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-center">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white">Home</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Administration" asp-action="ListRoles" class="text-white">Liste des roles</a></li>
                        <li class="breadcrumb-item text-white active" aria-current="page">@ViewData["Title"]</li>
                    </ol>
                </nav>

            </div>
        </div>
    </div>
</div>
<partial name="_Message" />
<!-- Header End -->


<div class="card card_border p-lg-5 p-3 mb-4">
    <div class="cards__heading">
        <h3> @ViewData["Title"] <span></span></h3>

    </div>
    <div class="card-body py-3 p-0">

        <div class="container">

            <form method="post" class="mt-3">
                <div class="form-group row">
                    <label asp-for="Id" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <input asp-for="Id" disabled class="form-control">
                    </div>
                </div>
                <div class="form-group row">
                    <label asp-for="RoleName" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <input asp-for="RoleName" class="form-control">
                        <span asp-validation-for="RoleName" class="text-danger"></span>
                    </div>
                </div>

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group row">
                    <div class="col-sm-10">
                        <button type="submit" class="btn btn-primary btn-style mt-4">Mettre à jour</button>
                        <a asp-action="ListRoles" class="btn btn-link btn-style mt-4">Annulé</a>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h3>Users in this role</h3>
                    </div>
                    <div class="card-body">
                        @if (Model.Users.Any())
                        {
                            foreach (var user in Model.Users)
                            {
            <h5 class="card-title">@user</h5> }
                        }
                        else
                        {
            <h5 class="card-title">None at the moment</h5>}
                    </div>
                    <div class="card-footer">
                        <a asp-controller="Administration" asp-action="EditUsersInRole"
                           asp-route-roleId="@Model.Id" class="btn btn-outline-success">
                            Ajouter ou supprimer des utilisateurs de ce rôle
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>















