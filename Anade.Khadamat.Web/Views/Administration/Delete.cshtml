@model Anade.Khadamat.Identity.UserStructure


@{
    ViewData["Title"] = "Supprimer utilisateur";
}


<!-- Header Start -->

<div class="container-fluid bg-primary py-2 mb-5 page-header">
    <div class="container py-2">
        <div class="row justify-content-center">
            <div class="col-lg-10 text-center">
                <h1 class="display-6 text-white animated slideInDown">@ViewData["Title"]</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-center">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white">Home</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Administration" asp-action="Index" class="text-white">Liste des roles</a></li>
                        <li class="breadcrumb-item text-white active" aria-current="page">@ViewData["Title"]</li>
                    </ol>
                </nav>

            </div>
        </div>
    </div>
</div>
<partial name="_Message" />
<!-- Header End -->

<div class="container">
    <div class="card">
        <div class="card-body">
            <div class="card-text"><h3>Êtes vous sûres de supprimer cet enregistrement ?</h3></div>
            <dl class="row">


                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Id)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Id)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.User.UserName)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.User.UserName)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Structure.Designation)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Structure.Designation)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.DateAffectation)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.DateAffectation.Date)
                </dd>


            </dl>


            <form asp-action="Delete">
                <input asp-for="Id" type="hidden" />
                <input type="submit" value="Delete" class="btn btn-outline-danger" />
                <a asp-action="Index" class="btn btn-outline-dark">Return</a>
            </form>


        </div>

    </div>
</div>
<br />
<br />

