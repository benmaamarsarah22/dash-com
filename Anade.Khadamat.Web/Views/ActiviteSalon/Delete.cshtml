@model Anade.Khadamat.Domain.Entity.ActiviteSalon

@{
    ViewData["Title"] = "حذف معرض / صالون";
    ViewData["FullWidth"] = true;
}

<div class="af-page" dir="rtl">

    <!-- HEADER -->
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-pencil-square"></i>
            </div>
            <div>
                <h1 class="af-header-title">حذف معرض / صالون</h1>
                <p class="af-header-sub">حذف بيانات المعرض من النظام</p>

                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <a asp-controller="ActiviteSalon" asp-action="Index">المعارض</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">تأكيد الحذف</span>
                </nav>
            </div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="container-fluid px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">

                <partial name="_Message" />

                <div class="card af-card shadow-sm mb-5">
                    <div class="card-body p-4 p-md-5">

                        <!-- ALERT -->
                        <div class="alert alert-danger d-flex align-items-center gap-3 mb-4 border-0 shadow-sm"
                             style="border-radius:12px;background-color:#fff5f5;">

                            <div class="af-stat-icon bg-danger text-white">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>

                            <div>
                                <h5 class="fw-bold mb-1 text-danger">هل أنت متأكد من الحذف؟</h5>
                                <p class="mb-0 text-dark small">
                                    لا يمكن التراجع عن هذا الإجراء. سيتم حذف جميع بيانات المعرض نهائياً.
                                </p>
                            </div>
                        </div>

                        <!-- SECTION -->
                        <div class="mb-4">
                            <span class="af-section-title">تفاصيل المعرض</span>
                        </div>

                        <div class="row g-4">

                            <!-- SUJET -->
                            <div class="col-12">
                                <label class="text-muted small d-block mb-1">موضوع المعرض</label>
                                <div class="p-3 bg-light rounded-3 fw-bold">
                                    @Model.Activite?.Sujet
                                </div>
                            </div>

                            <!-- LIEU -->
                            <div class="col-md-6">
                                <label class="text-muted small d-block mb-1">المكان</label>
                                <div class="p-2 border-bottom">
                                    <i class="bi bi-geo-alt me-2 text-primary"></i>
                                    @Model.Activite?.Lieu
                                </div>
                            </div>

                            <!-- DATE -->
                            <div class="col-md-6">
                                <label class="text-muted small d-block mb-1">التاريخ</label>
                                <div class="p-2 border-bottom">
                                    <i class="bi bi-calendar-event me-2 text-primary"></i>
                                    @Model.Activite?.DateActivite.ToString("dd/MM/yyyy")
                                </div>
                            </div>

                            <!-- VISITEURS -->
                            <div class="col-md-6">
                                <label class="text-muted small d-block mb-1">عدد الزوار</label>
                                <div class="p-2 border-bottom">
                                    <i class="bi bi-people me-2 text-primary"></i>
                                    @Model.Activite?.NombreVisiteurs
                                </div>
                            </div>

                            <!-- AGENCE -->
                            <div class="col-md-6">
                                <label class="text-muted small d-block mb-1">الهيئة</label>
                                <div class="p-2 border-bottom">
                                    <i class="bi bi-building me-2 text-primary"></i>
                                    @Model.Activite?.AgenceWilaya?.DesignationAr
                                </div>
                            </div>

                            <!-- ORGANISATEURS -->
                            <div class="col-12">
                                <label class="text-muted small d-block mb-1">المنظمين</label>
                                <div class="p-2 border-bottom">
                                    @Model.Activite?.Organisateurs
                                </div>
                            </div>

                            <!-- PARTICIPANTS -->
                            <div class="col-12">
                                <label class="text-muted small d-block mb-1">المشاركين</label>
                                <div class="p-3 bg-light rounded-3" style="min-height:60px;">
                                    @Model.Activite?.Participants
                                </div>
                            </div>

                        </div>

                        <hr class="my-5 opacity-10">

                        <!-- ACTIONS -->
                        <form asp-action="DeleteConfirmed" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="d-flex gap-3 justify-content-end">

                                <a asp-action="Index" class="btn btn-light px-4 fw-bold text-secondary">
                                    <i class="bi bi-arrow-right-circle me-1"></i> تراجع
                                </a>

                                <button type="submit"
                                        class="btn btn-danger px-5 fw-bold shadow-sm"
                                        id="btnConfirmDelete">
                                    <i class="bi bi-trash3 me-1"></i> تأكيد الحذف
                                </button>

                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnConfirmDelete').addEventListener('click', function () {
            const btn = this;

            btn.innerHTML = `
                <span class="spinner-border spinner-border-sm"></span>
                جاري الحذف...
            `;

            btn.classList.add('disabled');
        });
    </script>
}