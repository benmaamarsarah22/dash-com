@model Anade.Khadamat.Domain.Entity.ActiviteSalon

@{
    ViewData["Title"] = "تفاصيل المعرض / الصالون";
    ViewData["FullWidth"] = true;
}

<div class="af-page" dir="rtl">

    <!-- HEADER -->
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-collection"></i>
            </div>
            <div>
                <h1 class="af-header-title">تفاصيل المعرض / الصالون</h1>
                <p class="af-header-sub">عرض كامل لبيانات المعرض أو الصالون</p>

                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <a asp-controller="ActiviteSalon" asp-action="Index">المعارض والصالونات</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">عرض التفاصيل</span>
                </nav>
            </div>
        </div>

        <div class="af-page-header-right">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-af-add">
                <i class="bi bi-pencil-square me-1"></i> تعديل البيانات
            </a>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="container-fluid px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-9">

                <div class="card af-card shadow-sm mb-5 border-0">
                    <div class="card-body p-4 p-md-5">

                        <!-- SECTION 1 -->
                        <div class="mb-4">
                            <span class="af-section-title text-primary">
                                <i class="bi bi-card-heading me-2"></i>معلومات المعرض
                            </span>
                        </div>

                        <div class="row g-4 mb-5">

                            <!-- SUJET -->
                            <div class="col-12">
                                <div class="p-4 rounded-4" style="background:#f8faff; border-right:5px solid var(--primary);">
                                    <label class="text-muted small fw-bold mb-1">موضوع المعرض</label>
                                    <h3 class="fw-bold mb-0 text-dark">@Model.Activite?.Sujet</h3>
                                </div>
                            </div>

                            <!-- LIEU -->
                            <div class="col-md-4">
                                <div class="d-flex align-items-center p-3 border rounded-3 bg-white h-100">
                                    <div class="af-stat-icon bg-light text-primary me-3">
                                        <i class="bi bi-geo-alt-fill"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small">مكان المعرض</div>
                                        <div class="fw-bold">@Model.Activite?.Lieu</div>
                                    </div>
                                </div>
                            </div>

                            <!-- DATE -->
                            <div class="col-md-4">
                                <div class="d-flex align-items-center p-3 border rounded-3 bg-white h-100">
                                    <div class="af-stat-icon bg-light text-primary me-3">
                                        <i class="bi bi-calendar-event"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small">تاريخ المعرض</div>
                                        <div class="fw-bold">
                                            @Model.Activite?.DateActivite.ToString("dd MMMM yyyy")
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- VISITEURS -->
                            <div class="col-md-4">
                                <div class="d-flex align-items-center p-3 border rounded-3 bg-white h-100">
                                    <div class="af-stat-icon bg-light text-primary me-3">
                                        <i class="bi bi-people-fill"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small">عدد الزوار</div>
                                        <div class="fw-bold fs-5">@Model.Activite?.NombreVisiteurs</div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- SECTION 2 -->
                        <div class="mb-4 mt-5">
                            <span class="af-section-title text-primary">
                                <i class="bi bi-building me-2"></i>المشاركين والتنظيم
                            </span>
                        </div>

                        <div class="row g-4 mb-4">

                            <!-- ORGANISATEURS -->
                            <div class="col-md-6">
                                <div class="card h-100 border-0 bg-light rounded-4">
                                    <div class="card-body">
                                        <label class="text-muted small fw-bold mb-2 d-block">المنظمين</label>
                                        <p class="mb-0 fw-bold text-dark">@Model.Activite?.Organisateurs</p>
                                    </div>
                                </div>
                            </div>

                            <!-- PARTICIPANTS -->
                            <div class="col-md-6">
                                <div class="card h-100 border-0 bg-light rounded-4">
                                    <div class="card-body">
                                        <label class="text-muted small fw-bold mb-2 d-block">المشاركين</label>
                                        <p class="mb-0 fw-bold text-dark">@Model.Activite?.Participants</p>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <hr class="my-5 opacity-10">

                        <!-- ACTION -->
                        <div class="d-flex gap-3 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary px-4 fw-bold rounded-3">
                                <i class="bi bi-arrow-right-circle me-1"></i> العودة للقائمة
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>