@model Anade.Khadamat.Web.ViewModels.ActiviteSalonVM

@{
    ViewData["Title"] = "إضافة معرض / صالون";
    ViewData["FullWidth"] = true;
}

<div class="af-page" dir="rtl">

    <!-- HEADER -->
    <div class="af-page-header px-4 px-lg-5">
        <div class="af-page-header-left">
            <div class="af-header-icon">
                <i class="bi bi-collection"></i>
            </div>
            <div>
                <h1 class="af-header-title">المعارض والصالونات</h1>
                <p class="af-header-sub">إضافة معرض أو صالون جديد</p>

                <nav class="af-breadcrumb">
                    <a href="/"><i class="bi bi-house-fill"></i> الرئيسية</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <a asp-controller="ActiviteSalon" asp-action="Index">المعارض</a>
                    <span class="sep"><i class="bi bi-chevron-left"></i></span>
                    <span style="color:rgba(255,255,255,.75)">إضافة</span>
                </nav>
            </div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="container-fluid px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">

                <partial name="_Message" />

                <div class="card af-card shadow-sm mb-5">
                    <div class="card-body p-4 p-md-5">

                        <!-- TITLE -->
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="af-stat-icon shadow-sm" style="background: var(--light);">
                                <i class="bi bi-plus-circle-fill text-primary"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0">معلومات المعرض</h4>
                                <p class="text-muted small mb-0">يرجى إدخال معلومات المعرض بدقة</p>
                            </div>
                        </div>

                        <form asp-action="Create" method="post">
                            @Html.AntiForgeryToken()

                            <!-- SECTION -->
                            <div class="mb-4">
                                <span class="af-section-title">البيانات الأساسية</span>
                            </div>

                            <!-- SUJET -->
                            <div class="mb-3">
                                <label asp-for="Sujet" class="form-label fw-bold small">موضوع المعرض</label>
                                <input asp-for="Sujet" class="form-control af-form-input" placeholder="عنوان المعرض..." />
                                <span asp-validation-for="Sujet" class="text-danger small"></span>
                            </div>

                            <!-- LIEU -->
                            <div class="mb-3">
                                <label asp-for="Lieu" class="form-label fw-bold small">مكان المعرض</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-start-0">
                                        <i class="bi bi-geo-alt"></i>
                                    </span>
                                    <input asp-for="Lieu" class="form-control af-form-input" placeholder="مكان إقامة المعرض" />
                                </div>
                                <span asp-validation-for="Lieu" class="text-danger small"></span>
                            </div>

                            <!-- DATE + VISITEURS -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label asp-for="DateActivite" class="form-label fw-bold small">تاريخ المعرض</label>
                                    <input asp-for="DateActivite" type="date" class="form-control af-form-input" />
                                    <span asp-validation-for="DateActivite" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="NombreVisiteurs" class="form-label fw-bold small">عدد الزوار</label>
                                    <input asp-for="NombreVisiteurs" type="number" class="form-control af-form-input" placeholder="0" />
                                    <span asp-validation-for="NombreVisiteurs" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- SECTION -->
                            <div class="mb-4 mt-5">
                                <span class="af-section-title">التنظيم والمشاركة</span>
                            </div>

                            <!-- ORGANISATEURS -->
                            <div class="mb-3">
                                <label asp-for="Organisateurs" class="form-label fw-bold small">المنظمين</label>
                                <input asp-for="Organisateurs" class="form-control af-form-input" placeholder="جهات التنظيم..." />
                                <span asp-validation-for="Organisateurs" class="text-danger small"></span>
                            </div>

                            <!-- PARTICIPANTS -->
                            <div class="mb-5">
                                <label asp-for="Participants" class="form-label fw-bold small">المشاركين</label>
                                <textarea asp-for="Participants" class="form-control af-form-input" rows="3" placeholder="قائمة المشاركين..."></textarea>
                                <span asp-validation-for="Participants" class="text-danger small"></span>
                            </div>

                            <hr class="opacity-10 mb-4">

                            <!-- ACTIONS -->
                            <div class="d-flex gap-3 justify-content-end">
                                <a asp-action="Index" class="btn btn-light px-4 fw-bold">
                                    <i class="bi bi-x-circle me-1"></i> إلغاء
                                </a>

                                <button type="submit" class="btn btn-af-add px-5">
                                    <i class="bi bi-check-lg me-1"></i> حفظ المعرض
                                </button>
                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.querySelector('form');

            form.addEventListener('submit', function () {

                if ($(form).valid()) {
                    const btn = form.querySelector('button[type="submit"]');

                    btn.disabled = true;

                    btn.innerHTML = `
                        <span class="spinner-border spinner-border-sm"></span>
                        جاري الحفظ...
                    `;
                }
            });
        });
    </script>
}