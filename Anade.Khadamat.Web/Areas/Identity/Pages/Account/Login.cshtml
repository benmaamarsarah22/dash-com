@page
@model LoginModel

@{
    ViewData["Title"] = "Authentification";
}

<link href="~/Inscription/css/style.css" rel="stylesheet" />

<div id="booking" class="section">
    <div class="section-center">
        <div class="container">
            <div class="row">
                <div class="col-md-4">

                </div>
                <div class="col-md-4">
                    <div class="booking-form">
                        <form id="account" method="post" class="was-validated">
                            <div class="booking-cta">
                                <h4>Authentification</h4>
                            </div>

                            <hr />
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <div class="form-group">
                                <span class="form-label">Nom d'utilisateur'</span>
                                <input asp-for="Input.UserName" class="form-control" type="text" placeholder="UserName">
                            </div>
                            <div class="form-group">
                                <span class="form-label">Mot de passe</span>
                                <input asp-for="Input.Password" class="form-control" type="password" placeholder="Input.Password">
                            </div>
                            <div class="form-group">
                                <div class="form-checkbox">
                                    <label asp-for="Input.RememberMe">
                                        <input asp-for="Input.RememberMe" type="checkbox" />
                                        <span></span> Se souvenir de moi
                                    </label>
                                </div>
                            </div>

                            <div class="form-btn">
                                <button type="submit" class="submit-btn"> Connexion</button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<br />
<br />
<br />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
