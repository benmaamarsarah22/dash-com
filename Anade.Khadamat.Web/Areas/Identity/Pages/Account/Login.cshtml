@page
@model LoginModel

@{
    ViewData["Title"] = "Authentification";
}

<link href="~/Inscription/css/style.css" rel="stylesheet" />

<div id="booking" class="section">
    <div class="section-center">
        <div class="container">
            <div class="row">
                <div class="col-md-4">

                </div>
                <div class="col-md-4">
                    <div class="booking-form">
                        <form id="account" method="post" class="was-validated">
                            <div class="booking-cta">
                                <h4>تسجيل الدخول </h4>
                            </div>

                            <hr />
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <div class="form-group">
                                <span class="form-label d-block text-end" style="direction:rtl;width:85%;text-align:center">اسم المستخدم</span>
                                <input asp-for="Input.UserName" class="form-control" type="text" placeholder="اسم المستخدم">
                            </div>
                            <div class="form-group">
                                <span class="form-label d-block text-end" style="direction:rtl;width:85%;text-align:center">كلمة المرور</span>
                                <input asp-for="Input.Password" class="form-control" type="password" placeholder="أدخل كلمة المرور">
                            </div>
                            <div class="form-group">
                                <div class="form-checkbox">
                                    <label asp-for="Input.RememberMe">
                                        <input asp-for="Input.RememberMe" type="checkbox" />
                                        <span></span> تذكرني
                                    </label>
                                </div>
                            </div>

                            <div class="form-btn">
                                <button type="submit" class="submit-btn"> تسجيل الدخول</button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<br />
<br />
<br />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
