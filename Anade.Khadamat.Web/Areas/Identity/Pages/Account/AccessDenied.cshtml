@page
@model AccessDeniedModel
@{ ViewData["Title"] = "Access denied"; }


<div class="container-xxl py-5 wow fadeInUp" data-wow-delay="0.1s" style="visibility: visible; animation-delay: 0.1s; animation-name: fadeInUp;">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <i class="bi bi-exclamation-triangle display-1 text-primary"></i>
                <h1 class="display-1">Accès refusé</h1>
                <p class="mb-4">Désolé, Vous n'avez pas l'autorisation d'accèdé à cette ressource.</p>
                <a asp-action="Index" asp-controller="Home" class="btn btn-primary rounded-pill py-3 px-5">Retourner à la page d'accueil</a>
            </div>
        </div>
    </div>
</div>
